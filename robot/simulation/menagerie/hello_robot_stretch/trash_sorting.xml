<mujoco model="three19_trash_sorting">
  <compiler angle="radian"/>

  <include file="stretch.xml"/>

  <option timestep="0.002" gravity="0 0 -9.81" cone="elliptic" impratio="10" solver="Newton" iterations="100" integrator="implicitfast">
    <flag contact="enable"/>
  </option>

  <statistic center="1.5 0 0.6" extent="3.5" meansize="0.1"/>

  <visual>
    <global offwidth="640" offheight="480"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <quality shadowsize="2048"/>
    <rgba haze="0.1 0.2 0.3 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <!-- Two lights: overhead fill + directional -->
    <light name="overhead" directional="true" pos="1.5 0 3" dir="0 0 -1" diffuse="0.4 0.4 0.4"/>
    <light name="key" directional="true" pos="2 2 3" dir="-0.5 -0.5 -1" diffuse="0.7 0.7 0.7"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="2.5 2.5 0.01" material="groundplane"/>

    <!-- Walls -->
    <body name="wall_n" pos="2.5 0 0.4"><geom type="box" size="0.01 2.5 0.4" rgba="0.85 0.85 0.85 1"/></body>
    <body name="wall_s" pos="-2.5 0 0.4"><geom type="box" size="0.01 2.5 0.4" rgba="0.85 0.85 0.85 1"/></body>
    <body name="wall_e" pos="0 2.5 0.4"><geom type="box" size="2.5 0.01 0.4" rgba="0.85 0.85 0.85 1"/></body>
    <body name="wall_w" pos="0 -2.5 0.4"><geom type="box" size="2.5 0.01 0.4" rgba="0.85 0.85 0.85 1"/></body>

    <!-- Fixed observation camera -->
    <body name="overview_cam" pos="2.25 -1.45 1.85">
      <camera name="overview_cam" fovy="50" resolution="640 480" quat="0.82912305 0.40756393 0.16881851 0.34343401"/>
    </body>

    <!-- Work table -->
    <body name="table" pos="1.2 0 0.375">
      <geom type="box" size="0.65 0.35 0.375" rgba="0.55 0.35 0.15 1"/>
      <body name="table_top" pos="0 0 0.375">
        <geom type="box" size="0.65 0.35 0.006" rgba="0.7 0.5 0.3 1"/>
      </body>
    </body>

    <!-- 4 color-coded trash bins with label rings -->
    <body name="bin_recyclable" pos="0.35 0.72 0.18">
      <geom type="cylinder" size="0.12 0.18" rgba="0.2 0.3 0.9 1"/>
      <body pos="0 0 0.19"><geom type="cylinder" size="0.13 0.01" rgba="0.1 0.2 0.7 1"/></body>
    </body>
    <body name="bin_kitchen" pos="0.65 0.72 0.18">
      <geom type="cylinder" size="0.12 0.18" rgba="0.2 0.8 0.3 1"/>
      <body pos="0 0 0.19"><geom type="cylinder" size="0.13 0.01" rgba="0.1 0.6 0.2 1"/></body>
    </body>
    <body name="bin_hazardous" pos="0.35 -0.72 0.18">
      <geom type="cylinder" size="0.12 0.18" rgba="0.9 0.2 0.2 1"/>
      <body pos="0 0 0.19"><geom type="cylinder" size="0.13 0.01" rgba="0.7 0.1 0.1 1"/></body>
    </body>
    <body name="bin_other" pos="0.65 -0.72 0.18">
      <geom type="cylinder" size="0.12 0.18" rgba="0.5 0.5 0.5 1"/>
      <body pos="0 0 0.19"><geom type="cylinder" size="0.13 0.01" rgba="0.4 0.4 0.4 1"/></body>
    </body>

    <!-- 12 trash items covering 4 categories -->
    <body name="trash_01" pos="0.78 -0.20 0.856"><freejoint/>
      <geom type="cylinder" size="0.03 0.10" rgba="0.2 0.5 1.0 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_02" pos="1.6 -0.05 0.817"><freejoint/>
      <geom type="cylinder" size="0.025 0.06" rgba="0.7 0.7 0.7 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_03" pos="1.45 -0.10 0.781"><freejoint/>
      <geom type="sphere" size="0.025" rgba="0.8 0.2 0.2 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_04" pos="1.55 0.12 0.771"><freejoint/>
      <geom type="capsule" size="0.015" fromto="-0.04 0 0 0.04 0 0" rgba="0.9 0.9 0.1 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_05" pos="1.5 0.15 0.797"><freejoint/>
      <geom type="cylinder" size="0.01 0.04" rgba="0.3 0.3 0.3 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_06" pos="1.35 -0.12 0.761"><freejoint/>
      <geom type="box" size="0.03 0.04 0.005" rgba="1.0 0.5 0.5 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_07" pos="1.6 0.05 0.759"><freejoint/>
      <geom type="box" size="0.04 0.04 0.003" rgba="1.0 1.0 1.0 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_08" pos="1.35 0.02 0.758"><freejoint/>
      <geom type="box" size="0.05 0.06 0.002" rgba="1.0 1.0 0.8 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_09" pos="1.50 -0.18 0.837"><freejoint/>
      <geom type="cylinder" size="0.02 0.08" rgba="0.6 0.8 0.2 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_10" pos="1.30 0.15 0.786"><freejoint/>
      <geom type="sphere" size="0.03" rgba="0.9 0.7 0.1 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_11" pos="1.65 -0.15 0.769"><freejoint/>
      <geom type="capsule" size="0.012" fromto="-0.03 0 0 0.03 0 0" rgba="0.3 0.3 0.3 1" condim="4" friction="1.5 0.005 0.0001"/></body>
    <body name="trash_12" pos="1.40 0.0 0.764"><freejoint/>
      <geom type="box" size="0.06 0.04 0.008" rgba="0.8 0.8 0.9 1" condim="4" friction="1.5 0.005 0.0001"/></body>
  </worldbody>

  <!-- Grasp weld constraint (dynamic activation at runtime) -->
  <equality>
    <weld name="grasp_stretch" body1="link_gripper_finger_left"
          body2="trash_01" active="false" torquescale="5"/>
  </equality>
</mujoco>

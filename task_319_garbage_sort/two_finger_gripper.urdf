<?xml version="1.0"?>
<robot name="task319_two_finger_gripper">
  <link name="gripper_base">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.30"/>
      <inertia ixx="0.000080" ixy="0" ixz="0" iyy="0.000200" iyz="0" izz="0.000200"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.08 0.04 0.04"/></geometry>
      <material name="dark_gray"><color rgba="0.08 0.08 0.08 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.08 0.04 0.04"/></geometry>
    </collision>
  </link>

  <link name="left_finger">
    <inertial>
      <origin xyz="0.035 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.000023" ixy="0" ixz="0" iyy="0.000056" iyz="0" izz="0.000035"/>
    </inertial>
    <visual>
      <origin xyz="0.035 0 0"/>
      <geometry><box size="0.07 0.018 0.055"/></geometry>
      <material name="rubber"><color rgba="0.02 0.02 0.02 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.035 0 0"/>
      <geometry><box size="0.07 0.018 0.055"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.075 0 0"/>
      <geometry><box size="0.020 0.022 0.060"/></geometry>
      <material name="rubber_pad"><color rgba="0.01 0.01 0.01 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.075 0 0"/>
      <geometry><box size="0.020 0.022 0.060"/></geometry>
    </collision>
  </link>

  <link name="right_finger">
    <inertial>
      <origin xyz="0.035 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.000023" ixy="0" ixz="0" iyy="0.000056" iyz="0" izz="0.000035"/>
    </inertial>
    <visual>
      <origin xyz="0.035 0 0"/>
      <geometry><box size="0.07 0.018 0.055"/></geometry>
      <material name="rubber"><color rgba="0.02 0.02 0.02 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.035 0 0"/>
      <geometry><box size="0.07 0.018 0.055"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.075 0 0"/>
      <geometry><box size="0.020 0.022 0.060"/></geometry>
      <material name="rubber_pad"><color rgba="0.01 0.01 0.01 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.075 0 0"/>
      <geometry><box size="0.020 0.022 0.060"/></geometry>
    </collision>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.04 0.011 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.060" effort="70" velocity="0.18"/>
  </joint>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0.04 -0.011 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.060" effort="70" velocity="0.18"/>
  </joint>
  <gazebo reference="left_finger"><mu1>1.8</mu1><mu2>1.6</mu2><kp>100000</kp><kd>10</kd></gazebo>
  <gazebo reference="right_finger"><mu1>1.8</mu1><mu2>1.6</mu2><kp>100000</kp><kd>10</kd></gazebo>
</robot>

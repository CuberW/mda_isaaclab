def draw_overlay_qwen_first(image_path: Path, detections: list,
                             rejected: list, qwen_candidates: list,
                             overlay_path: Path) -> None:
    img = cv2.imread(str(image_path))
    if img is None:
        return
    overlay = img.copy()

    # Qwen coarse bboxes
    for c in qwen_candidates:
        bx = [int(round(v)) for v in c["bbox_xyxy"]]
        cv2.rectangle(overlay, (bx[0], bx[1]), (bx[2], bx[3]), (0, 200, 255), 1)
        cv2.putText(overlay, "VLM", (bx[0]+2, bx[1]+14),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.45, (0, 200, 255), 1, cv2.LINE_AA)

    # Rejected
    for r in rejected:
        roi = r.get("roi_crop_bbox_xyxy")
        if roi:
            rx = [int(round(v)) for v in roi]
            cv2.rectangle(overlay, (rx[0], rx[1]), (rx[2], rx[3]), (80, 80, 80), 1)
            reason_text = r.get("reject_reason", "rejected")[:20]
            cv2.putText(overlay, f"X {reason_text}", (rx[0]+2, rx[1]+14),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.38, (100, 100, 100), 1, cv2.LINE_AA)

    # Mask fill
    mask_layer = overlay.copy()
    for det in detections:
        cat   = det.get("garbage_category", "unknown")
        color = CATEGORY_COLOR.get(cat, CATEGORY_COLOR["unknown"])
        poly  = det.get("polygon")
        if poly and len(poly) >= 3:
            pts = np.array(poly, dtype=np.int32).reshape((-1, 1, 2))
            cv2.fillPoly(mask_layer, [pts], color)
    overlay = cv2.addWeighted(mask_layer, 0.28, overlay, 0.72, 0)

    for det in detections:
        cat   = det.get("garbage_category", "unknown")
        color = CATEGORY_COLOR.get(cat, CATEGORY_COLOR["unknown"])
        x1, y1, x2, y2 = [int(round(v)) for v in det["bbox_xyxy"]]

        roi_bbox = det.get("roi_crop_bbox_xyxy")
        if roi_bbox:
            rx = [int(round(v)) for v in roi_bbox]
            cv2.rectangle(overlay, (rx[0], rx[1]), (rx[2], rx[3]), (255, 200, 0), 1)

        cv2.rectangle(overlay, (x1, y1), (x2, y2), color, 2)
        poly = det.get("polygon")
        if poly and len(poly) >= 3:
            pts = np.array(poly, dtype=np.int32).reshape((-1, 1, 2))
            cv2.polylines(overlay, [pts], isClosed=True, color=color, thickness=2)

        cat_cn = CATEGORY_CN.get(cat, cat)
        conf   = det.get("confidence", 0.0)
        label  = f"{cat_cn} {conf:.2f}"
        font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1
        (tw, th), bl = cv2.getTextSize(label, font, fscale, thick)
        ly = y1 - 5 if y1 - 5 > 15 else y1 + 15
        cv2.rectangle(overlay, (x1, ly-th-2), (x1+tw+4, ly+bl), color, -1)
        cv2.putText(overlay, label, (x1+2, ly-2), font, fscale,
                    (255, 255, 255), thick, cv2.LINE_AA)

        c_px = det.get("centroid_px")
        if c_px:
            cv2.circle(overlay, (int(c_px[0]), int(c_px[1])), 3, (255, 255, 0), -1)
        b_px = det.get("bottom_contact_px")
        if b_px:

def save_json_atomic(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
    tmp.replace(path)


def encode_image_base64(image_path: Path) -> str:
    with open(image_path, "rb") as fh:
        return base64.b64encode(fh.read()).decode("utf-8")


def polygon_centroid(poly) -> list:
    if poly is None or len(poly) < 3:
        return None
    pts = np.array(poly, dtype=np.float32)
    m = cv2.moments(pts)
    if abs(m["m00"]) < 1e-6:
        return None
    cx = float(m["m10"] / m["m00"])
    cy = float(m["m01"] / m["m00"])
    return [round(cx, 2), round(cy, 2)]


def compute_bottom_contact(polygon: list, bbox_xyxy: list) -> list:
    """Compute the bottom-contact pixel from mask polygon (original-image coords)."""
    x1, y1, x2, y2 = bbox_xyxy
    if not polygon or len(polygon) < 3:
        return [round(float((x1 + x2) / 2.0), 3), round(float(y2), 3)]
    pts = np.array(polygon, dtype=np.float32)
    y_coords = pts[:, 1]
    y_max = float(np.max(y_coords))
    bbox_h = y2 - y1
    threshold = y_max - 0.08 * bbox_h
    bottom_pts = pts[y_coords >= threshold]
    if len(bottom_pts) == 0:
        return [round(float((x1 + x2) / 2.0), 3), round(float(y2), 3)]
    bottom_x = float(np.mean(bottom_pts[:, 0]))
    bottom_y = float(np.mean(bottom_pts[:, 1]))
    return [round(bottom_x, 3), round(bottom_y, 3)]


def clamp(v, lo, hi):
    return max(lo, min(hi, v))


# ---------------------------------------------------------------------------
# ROI helpers
# ---------------------------------------------------------------------------

def expand_bbox_to_square(bbox_xyxy: list, img_w: int, img_h: int,
                           expand_ratio: float = 2.0) -> list:
    """
    Expand Qwen bbox to a padded square ROI.
    Returns [crop_x1, crop_y1, crop_x2, crop_y2] clamped to image bounds.
    """
    x1, y1, x2, y2 = bbox_xyxy
    cx = (x1 + x2) / 2.0
    cy = (y1 + y2) / 2.0
    w = x2 - x1
    h = y2 - y1
    side = max(w, h) * expand_ratio / 2.0
    crop_x1 = int(clamp(cx - side, 0, img_w - 1))
    crop_y1 = int(clamp(cy - side, 0, img_h - 1))
    crop_x2 = int(clamp(cx + side, 0, img_w - 1))
    crop_y2 = int(clamp(cy + side, 0, img_h - 1))
    if crop_x2 <= crop_x1:
        crop_x2 = min(img_w - 1, crop_x1 + 1)
    if crop_y2 <= crop_y1:
        crop_y2 = min(img_h - 1, crop_y1 + 1)
    return [crop_x1, crop_y1, crop_x2, crop_y2]


def bbox_iou(a: list, b: list) -> float:
    """Compute IoU between two [x1,y1,x2,y2] boxes."""
    ix1 = max(a[0], b[0])
    iy1 = max(a[1], b[1])
    ix2 = min(a[2], b[2])
    iy2 = min(a[3], b[3])
    inter_w = max(0.0, ix2 - ix1)
    inter_h = max(0.0, iy2 - iy1)
    inter = inter_w * inter_h
    if inter == 0:
        return 0.0
    area_a = max(0.0, (a[2] - a[0]) * (a[3] - a[1]))
    area_b = max(0.0, (b[2] - b[0]) * (b[3] - b[1]))
    union = area_a + area_b - inter
    return inter / union if union > 0 else 0.0


# ---------------------------------------------------------------------------
# Approach-required judgement
# ---------------------------------------------------------------------------

def compute_approach_required(bbox_xyxy: list, qwen_coarse_conf: float,
                               img_w: int, img_h: int):
    """Return (approach_required: bool, reason: str)."""
    x1, y1, x2, y2 = bbox_xyxy
    bbox_h = y2 - y1
    cx = (x1 + x2) / 2.0
    img_cx = img_w / 2.0

    if bbox_h / max(1, img_h) < 0.08:
        return True, "target_too_small"
    if qwen_coarse_conf < 0.55:
        return True, "low_confidence"
    if abs(cx - img_cx) > img_w * 0.25:
        return True, "off_center"
    return False, "none"



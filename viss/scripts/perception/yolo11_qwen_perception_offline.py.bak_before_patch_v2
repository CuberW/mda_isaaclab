        "* \u673a\u5668\u4eba\u673a\u68b0\u81c2\n* \u673a\u5668\u4eba\u5939\u722a\n* \u684c\u5b50\n* \u5730\u9762\n* \u5899\u9762\n"
        "* \u9634\u5f71\n* \u5783\u573e\u6876\n* \u5783\u573e\u6876\u8fb9\u7f18\n* \u4f20\u611f\u5668\u3001\u652f\u67b6\u3001\u7ebf\u7f06\n"
        "* \u4efb\u4f55\u660e\u663e\u4e0d\u662f\u5783\u573e\u7684\u80cc\u666f\u7269\u4f53\n\n"
        "\u8bf7\u8f93\u51fa\u4e25\u683c JSON\uff0c\u4e0d\u8981\u8f93\u51fa\u89e3\u91ca\u6027\u6587\u5b57\u3002\n\n"
        "\u8f93\u51fa\u683c\u5f0f\uff1a\n"
        "{\n"
        "  \"candidates\": [\n"
        "    {\n"
        "      \"candidate_id\": \"vlm_candidate_001\",\n"
        "      \"object_name\": \"...\",\n"
        "      \"is_graspable_trash\": true,\n"
        "      \"garbage_category_guess\": \"recyclable|kitchen|hazardous|other|unknown\",\n"
        "      \"bbox_xyxy\": [x1, y1, x2, y2],\n"
        "      \"center_px\": [u, v],\n"
        "      \"confidence\": 0.0,\n"
        "      \"reason\": \"...\"\n"
        "    }\n"
        "  ]\n"
        "}\n\n"
        "\u8981\u6c42\uff1a\n"
        "- bbox_xyxy \u4f7f\u7528\u539f\u56fe\u50cf\u7d20\u5750\u6807\u3002\n"
        "- \u53ea\u8f93\u51fa\u53ef\u6293\u53d6\u5783\u573e\u5019\u9009\u3002\n"
        "- \u5982\u679c\u4e0d\u786e\u5b9a\u662f\u5426\u4e3a\u5783\u573e\uff0cis_graspable_trash=false\u3002\n"
        "- \u5982\u679c\u56fe\u4e2d\u6ca1\u6709\u660e\u786e\u5783\u573e\uff0ccandidates \u8f93\u51fa\u7a7a\u6570\u7ec4\u3002\n"
        "- confidence \u8303\u56f4\u4e3a 0 \u5230 1\u3002\n"
        "- \u53ea\u8f93\u51fa JSON\u3002"
    )

    raw_text = _post_qwen(base_url, api_key, model_name, prompt, image_path)
    if not raw_text:
        return []

    try:
        cleaned = _extract_json_from_text(raw_text)
        parsed = json.loads(cleaned)
    except Exception as e:
        print(f"[QWEN COARSE PARSE ERROR] {repr(e)}\nRaw:\n{raw_text[:500]}")
        return []

    raw_candidates = parsed.get("candidates", [])
    if not isinstance(raw_candidates, list):
        return []

    valid = []
    for idx, c in enumerate(raw_candidates):
        cid = c.get("candidate_id", f"vlm_candidate_{idx+1:03d}")
        obj_name = c.get("object_name", "unknown_object")
        is_graspable = c.get("is_graspable_trash", False)
        if not isinstance(is_graspable, bool):
            is_graspable = bool(is_graspable)
        cat_guess = c.get("garbage_category_guess", "unknown").lower().strip()
        if cat_guess not in ALLOWED_CATEGORIES:
            cat_guess = "unknown"
        conf = c.get("confidence", 0.0)
        try:
            conf = float(conf)
        except Exception:
            conf = 0.0
        reason = c.get("reason", "")

        bbox = c.get("bbox_xyxy", [])
        if not isinstance(bbox, list) or len(bbox) != 4:
            print(f"[QWEN COARSE] Candidate {cid} invalid bbox, skip")
            continue
        try:
            bx1, by1, bx2, by2 = [float(v) for v in bbox]
        except Exception:
            continue

        bx1 = clamp(bx1, 0, img_w - 1)
        bx2 = clamp(bx2, 0, img_w - 1)
        by1 = clamp(by1, 0, img_h - 1)
        by2 = clamp(by2, 0, img_h - 1)

        if bx2 <= bx1 or by2 <= by1:
            print(f"[QWEN COARSE] Candidate {cid} invalid bbox after clamp")
            continue

        center = c.get("center_px", [(bx1+bx2)/2, (by1+by2)/2])
        try:
            center = [float(center[0]), float(center[1])]
        except Exception:
            center = [(bx1+bx2)/2, (by1+by2)/2]

        valid.append({
            "candidate_id":           cid,
            "object_name":            obj_name,
            "is_graspable_trash":     is_graspable,
            "garbage_category_guess": cat_guess,
            "bbox_xyxy":              [bx1, by1, bx2, by2],
            "center_px":              center,
            "confidence":             conf,
            "reason":                 reason,
        })

    print(f"[QWEN COARSE] {len(valid)}/{len(raw_candidates)} valid candidates")
    return valid



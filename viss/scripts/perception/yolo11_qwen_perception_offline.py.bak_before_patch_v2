def _get_qwen_config():
    """Return (api_key, base_url, model_name). Sets QWEN_MOCK_MODE if keys missing."""
    global QWEN_MOCK_MODE
    api_key    = os.environ.get("QWEN_API_KEY",  "").strip()
    base_url   = os.environ.get("QWEN_BASE_URL", "").strip()
    model_name = os.environ.get("QWEN_MODEL",    "").strip()
    if not model_name:
        model_name = "qwen3-vl-flash"
    if not api_key or not base_url:
        if not QWEN_MOCK_MODE:
            print("[QWEN MOCK] missing QWEN_API_KEY or QWEN_BASE_URL")
        QWEN_MOCK_MODE = True
    else:
        QWEN_MOCK_MODE = False
    return api_key, base_url, model_name


def _extract_json_from_text(text: str) -> str:
    """Strip markdown fences and return the first JSON object found."""
    cleaned = text.strip()
    cleaned = re.sub(r"^```(?:json)?\s*\n?", "", cleaned)
    cleaned = re.sub(r"\n?```\s*$", "", cleaned)
    cleaned = cleaned.strip()
    if not ((cleaned.startswith("{") and cleaned.endswith("}")) or
            (cleaned.startswith("[") and cleaned.endswith("]"))):
        m = re.search(r"(\{.*\}|\[.*\])", cleaned, re.DOTALL)
        if m:
            cleaned = m.group(1).strip()
    return cleaned


def _post_qwen(base_url: str, api_key: str, model_name: str,
               prompt: str, image_path: Path, timeout: int = 45):
    """POST to Qwen OpenAI-compatible endpoint, return raw text or None."""
    try:
        b64 = encode_image_base64(image_path)
    except Exception as e:
        print(f"[QWEN ERROR] Failed to encode image {image_path}: {repr(e)}")
        return None

    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    data = {
        "model": model_name,
        "messages": [
            {
                "role": "user",
                "content": [
                    {"type": "text", "text": prompt},
                    {"type": "image_url",
                     "image_url": {"url": f"data:image/jpeg;base64,{b64}"}},
                ],
            }
        ],
    }
    url = f"{base_url.rstrip('/')}/chat/completions"
    t0 = time.time()
    try:
        resp = requests.post(url, headers=headers, json=data, timeout=timeout)
        dur = time.time() - t0
        if resp.status_code != 200:
            print(f"[QWEN ERROR] HTTP {resp.status_code}: {resp.text[:300]}")
            return None
        content = resp.json()["choices"][0]["message"]["content"]
        print(f"[QWEN] Response in {dur:.2f}s for {image_path.name}")
        return content
    except Exception as e:
        print(f"[QWEN ERROR] Request failed: {repr(e)}")
        return None



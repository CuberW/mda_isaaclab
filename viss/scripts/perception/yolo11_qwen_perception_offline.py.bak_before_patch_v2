    return classify_crop_with_qwen(crop_path, raw_class)


def mock_qwen_result(raw_class: str) -> dict:
    return _mock_qwen_classify(raw_class)


# ---------------------------------------------------------------------------
# YOLO ROI refined segmentation  (qwen_first step-2)
# ---------------------------------------------------------------------------

def refine_trash_with_yolo_roi(image: np.ndarray,
                                img_w: int, img_h: int,
                                qwen_candidate: dict,
                                model,
                                roi_expand: float,
                                conf_thresh: float,
                                min_area_ratio: float,
                                roi_save_dir: Path) -> dict:
    """
    Run YOLO11-seg on the ROI defined by Qwen candidate bbox.
    All returned coords are in ORIGINAL image space.
    """
    qwen_bbox = qwen_candidate["bbox_xyxy"]
    image_area = img_w * img_h

    for attempt, expand in enumerate([roi_expand, 3.0], start=1):
        crop_bbox = expand_bbox_to_square(qwen_bbox, img_w, img_h, expand)
        cx1, cy1, cx2, cy2 = crop_bbox

        roi_img = image[cy1:cy2, cx1:cx2]
        if roi_img.size == 0:
            continue
        roi_w = cx2 - cx1
        roi_h = cy2 - cy1

        roi_save_dir.mkdir(parents=True, exist_ok=True)
        cid = qwen_candidate.get("candidate_id", "roi")
        roi_filename = f"{cid}_expand{expand:.1f}.jpg"
        roi_path = roi_save_dir / roi_filename
        cv2.imwrite(str(roi_path), roi_img)

        results = model.predict(source=roi_img, conf=conf_thresh, verbose=False)
        result = results[0]
        boxes = result.boxes
        masks = result.masks

        if boxes is None or len(boxes) == 0:
            print(f"[YOLO ROI] No detection (expand={expand:.1f}, attempt {attempt})")
            if attempt == 1:
                continue
            return {"success": False, "reason": "no_yolo_detection_in_roi",
                    "crop_bbox": crop_bbox, "crop_path": str(roi_path)}

        names = result.names
        qwen_cx = (qwen_bbox[0] + qwen_bbox[2]) / 2.0
        qwen_cy = (qwen_bbox[1] + qwen_bbox[3]) / 2.0
        qwen_roi_bbox = [
            clamp(qwen_bbox[0] - cx1, 0, roi_w),
            clamp(qwen_bbox[1] - cy1, 0, roi_h),
            clamp(qwen_bbox[2] - cx1, 0, roi_w),
            clamp(qwen_bbox[3] - cy1, 0, roi_h),
        ]

        best_idx = None
        best_score = -1.0
        max_dist = (img_w**2 + img_h**2) ** 0.5

        for i, box in enumerate(boxes):
            xyxy = box.xyxy[0].detach().cpu().numpy().astype(float).tolist()
            bx1, by1, bx2, by2 = xyxy
            bx1 = clamp(bx1, 0, roi_w)
            bx2 = clamp(bx2, 0, roi_w)
            by1 = clamp(by1, 0, roi_h)
            by2 = clamp(by2, 0, roi_h)
            if bx2 <= bx1 or by2 <= by1:
                continue
            area = (bx2 - bx1) * (by2 - by1)
            if area / max(1, image_area) < min_area_ratio:
                continue
            det_cx = (bx1 + bx2) / 2.0 + cx1
            det_cy = (by1 + by2) / 2.0 + cy1
            dist = ((det_cx - qwen_cx)**2 + (det_cy - qwen_cy)**2) ** 0.5
            iou = bbox_iou(qwen_roi_bbox, [bx1, by1, bx2, by2])
            yolo_conf = float(box.conf[0].item())
            norm_dist = dist / max(1.0, max_dist)
            score = iou * 0.5 + yolo_conf * 0.3 + (1.0 - norm_dist) * 0.2
            if score > best_score:
                best_score = score
                best_idx = i

        if best_idx is None:
            print(f"[YOLO ROI] All boxes below threshold (expand={expand:.1f})")
            if attempt == 1:
                continue
            return {"success": False, "reason": "yolo_boxes_below_area_threshold",
                    "crop_bbox": crop_bbox, "crop_path": str(roi_path)}

        # Extract best detection
        box = boxes[best_idx]
        cls_id = int(box.cls[0].item())
        raw_class_name = names[cls_id]
        yolo_conf = float(box.conf[0].item())
        xyxy = box.xyxy[0].detach().cpu().numpy().astype(float).tolist()
        bx1, by1, bx2, by2 = xyxy
        bx1 = clamp(bx1, 0, roi_w)
        bx2 = clamp(bx2, 0, roi_w)
        by1 = clamp(by1, 0, roi_h)
        by2 = clamp(by2, 0, roi_h)

        # Restore to original image coords
        ox1 = bx1 + cx1
        oy1 = by1 + cy1
        ox2 = bx2 + cx1
        oy2 = by2 + cy1
        bbox_w = ox2 - ox1
        bbox_h = oy2 - oy1
        area_ratio = (bbox_w * bbox_h) / max(1, image_area)

        polygon = []
        centroid = None
        if masks is not None and getattr(masks, "xy", None) is not None \
                and best_idx < len(masks.xy):
            poly_roi = masks.xy[best_idx]
            for px, py in poly_roi:
                polygon.append([round(float(px) + cx1, 3),
                                 round(float(py) + cy1, 3)])
            centroid = polygon_centroid(np.array(polygon, dtype=np.float32))

        if centroid is None:
            centroid = [round(float((ox1 + ox2) / 2.0), 3),
                        round(float((oy1 + oy2) / 2.0), 3)]

        bottom_contact_px = compute_bottom_contact(polygon, [ox1, oy1, ox2, oy2])

        # Save final crop
        pad_x = bbox_w * 0.15
        pad_y = bbox_h * 0.15
        fc_x1 = max(0, int(ox1 - pad_x))
        fc_y1 = max(0, int(oy1 - pad_y))
        fc_x2 = min(img_w, int(ox2 + pad_x))
        fc_y2 = min(img_h, int(oy2 + pad_y))
        final_crop_img = image[fc_y1:fc_y2, fc_x1:fc_x2]
        final_crop_path = roi_save_dir / f"{cid}_final_crop.jpg"
        cv2.imwrite(str(final_crop_path), final_crop_img)

        return {
            "success":           True,
            "crop_bbox":         crop_bbox,
            "crop_path":         str(roi_path),
            "final_crop_path":   str(final_crop_path),
            "raw_class_name":    raw_class_name,
            "yolo_confidence":   round(yolo_conf, 4),
            "bbox_xyxy":         [round(ox1, 3), round(oy1, 3),
                                   round(ox2, 3), round(oy2, 3)],
            "centroid_px":       centroid,
            "bottom_contact_px": bottom_contact_px,
            "bbox_area_ratio":   round(area_ratio, 6),
            "polygon":           polygon,
            "bbox_h":            bbox_h,
        }

    return {"success": False, "reason": "failed_yolo_refine"}



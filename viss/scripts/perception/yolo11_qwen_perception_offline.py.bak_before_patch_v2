# Pipeline: yolo_first  (original — kept intact as fallback)
# ---------------------------------------------------------------------------

def run_yolo_first(image_path: Path, model, args,
                   img: np.ndarray, orig_w: int, orig_h: int,
                   crop_dir: Path):
    """
    Original YOLO-first pipeline.
    Returns (detections, rejected_detections, yolo_infer_sec).
    """
    image_area = orig_w * orig_h
    t0 = time.time()
    results = model.predict(source=str(image_path), conf=args.conf, verbose=False)
    yolo_infer_sec = time.time() - t0

    result = results[0]
    names  = result.names
    boxes  = result.boxes
    masks  = result.masks

    detections = []
    rejected_detections = []

    if boxes is None:
        return detections, rejected_detections, yolo_infer_sec

    for i, box in enumerate(boxes):
        cls_id         = int(box.cls[0].item())
        raw_class_name = names[cls_id]
        yolo_conf      = float(box.conf[0].item())

        xyxy = box.xyxy[0].detach().cpu().numpy().astype(float).tolist()
        x1, y1, x2, y2 = xyxy
        x1 = clamp(x1, 0, orig_w - 1)
        x2 = clamp(x2, 0, orig_w - 1)
        y1 = clamp(y1, 0, orig_h - 1)
        y2 = clamp(y2, 0, orig_h - 1)
        if x2 <= x1 or y2 <= y1:
            continue

        bbox_w = x2 - x1
        bbox_h = y2 - y1
        area_ratio = (bbox_w * bbox_h) / max(1.0, image_area)

        if area_ratio > args.max_area_ratio:
            print(f"[YOLO FIRST FILTER] area_ratio {area_ratio:.3f} > {args.max_area_ratio}")
            rejected_detections.append({
                "raw_class_name": raw_class_name,
                "bbox_xyxy":      [x1, y1, x2, y2],
                "reject_reason":  "area_ratio_too_large",
            })
            continue

        polygon  = []
        centroid = None
        if masks is not None and getattr(masks, "xy", None) is not None \
                and i < len(masks.xy):
            poly_np = masks.xy[i]
            for px, py in poly_np:
                polygon.append([round(float(px), 3), round(float(py), 3)])
            centroid = polygon_centroid(poly_np)

        if centroid is None:
            centroid = [round(float((x1+x2)/2.0), 3),
                        round(float((y1+y2)/2.0), 3)]

        bottom_contact_px = compute_bottom_contact(polygon, [x1, y1, x2, y2])

        pad_x = bbox_w * 0.15
        pad_y = bbox_h * 0.15
        c_x1 = max(0, int(x1 - pad_x))
        c_y1 = max(0, int(y1 - pad_y))
        c_x2 = min(orig_w, int(x2 + pad_x))
        c_y2 = min(orig_h, int(y2 + pad_y))
        crop_img  = img[c_y1:c_y2, c_x1:c_x2]
        det_id    = len(detections) + 1
        crop_path = crop_dir / f"det_{det_id:03d}_crop.jpg"
        cv2.imwrite(str(crop_path), crop_img)

        qwen_res        = call_qwen_api(crop_path, raw_class_name)
        garbage_category = qwen_res.get("garbage_category", "unknown")
        target_bin       = qwen_res.get("target_bin", "unknown")
        qwen_conf        = qwen_res.get("confidence", 0.5)

        if qwen_conf <= 0.0:
            combined_conf = round(yolo_conf * 0.8, 4)
        else:
            combined_conf = round(min(yolo_conf, qwen_conf), 4)

        approach_required, approach_reason = compute_approach_required(
            [x1, y1, x2, y2], qwen_conf, orig_w, orig_h)

        det = {
            "object_id":            f"yolo11_qwen_det_{det_id:03d}",
            "raw_class_name":       raw_class_name,
            "raw_object_id":        f"yolo_det_{det_id:03d}",
            "class_name":           "trash_object",
            "display_name":         "trash_object",
            "category":             "trash_object",
            "garbage_category":     garbage_category,
            "garbage_category_cn":  CATEGORY_CN.get(garbage_category, "\u672a\u77e5"),
            "target_bin":           target_bin,
            "target_bin_cn":        BIN_CN.get(target_bin, "unknown"),
            "confidence":           combined_conf,
            "yolo_confidence":      round(yolo_conf, 4),
            "qwen_confidence":      round(qwen_conf, 4),
            "bbox_xyxy":            [round(x1,3), round(y1,3), round(x2,3), round(y2,3)],
            "centroid_px":          centroid,
            "bottom_contact_px":    bottom_contact_px,
            "bbox_area_ratio":      round(area_ratio, 6),
            "polygon":              polygon,
            "crop_path":            str(crop_path),
            "approach_required":    approach_required,
            "approach_reason":      approach_reason,
            "qwen_result":          qwen_res,
            "source":               "yolo11_seg_qwen",
        }
        detections.append(det)

    return detections, rejected_detections, yolo_infer_sec


# ---------------------------------------------------------------------------
# Pipeline: qwen_first
# ---------------------------------------------------------------------------

def run_qwen_first(image_path: Path, model, args,
                   img: np.ndarray, orig_w: int, orig_h: int,
                   timestamp: str):
    """
    Qwen-first pipeline.
    Returns (detections, rejected_detections, total_sec, qwen_candidates).
    """
    t_start = time.time()
    image_area = orig_w * orig_h

    roi_dir = ROOT / "data" / "crops" / "qwen_roi" / timestamp
    roi_dir.mkdir(parents=True, exist_ok=True)

    # Step 1: Qwen coarse locate
    qwen_candidates = coarse_locate_trash_with_qwen(image_path, orig_w, orig_h)

    if not qwen_candidates:
        if QWEN_MOCK_MODE:
            print("[QWEN MOCK] qwen_first requires API, fallback to yolo_first")
            crop_dir = ROOT / "data" / "crops" / "qwen" / timestamp
            crop_dir.mkdir(parents=True, exist_ok=True)
            dets, rejects, yolo_sec = run_yolo_first(
                image_path, model, args, img, orig_w, orig_h, crop_dir)
            return dets, rejects, time.time() - t_start, []
        else:
            print("[QWEN FIRST] No candidates from Qwen")
            return [], [], time.time() - t_start, []

    detections = []
    rejected_detections = []

    for candidate in qwen_candidates:
        cid              = candidate["candidate_id"]
        qwen_coarse_conf = candidate["confidence"]
        is_graspable     = candidate["is_graspable_trash"]

        if not is_graspable:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":  candidate["bbox_xyxy"],
                "reject_reason":   "qwen_coarse_not_graspable",
                "candidate_id":    cid,
            })
            continue

        if qwen_coarse_conf < args.qwen_coarse_conf:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":  candidate["bbox_xyxy"],
                "reject_reason":   f"qwen_coarse_conf_too_low({qwen_coarse_conf:.2f})",
                "candidate_id":    cid,
            })
            continue

        bx1, by1, bx2, by2 = candidate["bbox_xyxy"]
        if bx2 <= bx1 or by2 <= by1:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "reject_reason":   "invalid_qwen_bbox",
                "candidate_id":    cid,
            })
            continue

        # Step 2: YOLO ROI refine
        yolo_result = refine_trash_with_yolo_roi(
            image=img, img_w=orig_w, img_h=orig_h,
            qwen_candidate=candidate,
            model=model,
            roi_expand=args.roi_expand,
            conf_thresh=args.conf,
            min_area_ratio=args.min_area_ratio,
            roi_save_dir=roi_dir,
        )

        if not yolo_result["success"]:
            rejected_detections.append({
                "raw_class_name":     candidate["object_name"],
                "bbox_xyxy":          candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      yolo_result.get("reason", "failed_yolo_refine"),
                "candidate_id":       cid,
            })
            continue

        if yolo_result["bbox_area_ratio"] < args.min_area_ratio:
            rejected_detections.append({
                "raw_class_name":     yolo_result["raw_class_name"],
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      f"yolo_area_too_small({yolo_result['bbox_area_ratio']:.6f})",
                "candidate_id":       cid,
            })
            continue

        if yolo_result["bbox_area_ratio"] > args.max_area_ratio:
            rejected_detections.append({
                "raw_class_name":     yolo_result["raw_class_name"],
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      f"yolo_area_too_large({yolo_result['bbox_area_ratio']:.3f})",
                "candidate_id":       cid,
            })
            continue

        # Step 3: Qwen classify crop
        final_crop_path = Path(yolo_result.get("final_crop_path",
                                               yolo_result["crop_path"]))
        raw_class_name  = yolo_result["raw_class_name"]
        qwen_verify_res = classify_crop_with_qwen(final_crop_path, raw_class_name)

        qwen_verify_conf    = qwen_verify_res.get("confidence", 0.0)
        verify_is_graspable = qwen_verify_res.get("is_graspable_trash", True)
        garbage_category    = qwen_verify_res.get("garbage_category", "unknown")

        if not verify_is_graspable:
            rejected_detections.append({
                "raw_class_name":     raw_class_name,
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      "qwen_verify_not_graspable",
                "candidate_id":       cid,
                "qwen_verify_result": qwen_verify_res,
            })
            continue

        if qwen_verify_conf < args.qwen_verify_conf:
            rejected_detections.append({
                "raw_class_name":     raw_class_name,
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      f"qwen_verify_conf_too_low({qwen_verify_conf:.2f})",
                "candidate_id":       cid,
                "qwen_verify_result": qwen_verify_res,
            })
            continue

        if garbage_category == "unknown" and not args.allow_unknown:
            rejected_detections.append({
                "raw_class_name":     raw_class_name,
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      "garbage_category_unknown_not_allowed",
                "candidate_id":       cid,
                "qwen_verify_result": qwen_verify_res,
            })
            continue

        target_bin = qwen_verify_res.get("target_bin", "unknown")
        yolo_conf  = yolo_result["yolo_confidence"]

        combined_conf = round(min(
            qwen_coarse_conf if qwen_coarse_conf > 0 else 0,
            yolo_conf        if yolo_conf > 0        else 0,
            qwen_verify_conf if qwen_verify_conf > 0 else 0,
        ), 4)

        det_id = len(detections) + 1
        approach_required, approach_reason = compute_approach_required(
            yolo_result["bbox_xyxy"], qwen_coarse_conf, orig_w, orig_h)

        det = {
            "object_id":           f"qwen_yolo_det_{det_id:03d}",
            "raw_class_name":      raw_class_name,
            "raw_object_id":       cid,
            "class_name":          "trash_object",
            "display_name":        "trash_object",
            "category":            "trash_object",
            "garbage_category":    garbage_category,
            "garbage_category_cn": CATEGORY_CN.get(garbage_category, "\u672a\u77e5"),
            "target_bin":          target_bin,
            "target_bin_cn":       BIN_CN.get(target_bin, "unknown"),
            "confidence":              combined_conf,
            "qwen_coarse_confidence":  round(qwen_coarse_conf, 4),
            "yolo_confidence":         round(yolo_conf, 4),
            "qwen_verify_confidence":  round(qwen_verify_conf, 4),
            "bbox_xyxy":           yolo_result["bbox_xyxy"],
            "centroid_px":         yolo_result["centroid_px"],
            "bottom_contact_px":   yolo_result["bottom_contact_px"],
            "bbox_area_ratio":     yolo_result["bbox_area_ratio"],
            "polygon":             yolo_result["polygon"],
            "qwen_bbox_xyxy":      candidate["bbox_xyxy"],
            "roi_crop_bbox_xyxy":  yolo_result.get("crop_bbox"),
            "roi_crop_path":       yolo_result["crop_path"],
            "crop_path":           str(final_crop_path),
            "approach_required":   approach_required,
            "approach_reason":     approach_reason,
            "qwen_coarse_result":  candidate,
            "qwen_verify_result":  qwen_verify_res,
            "source":              "qwen_first_yolo11_roi",
        }
        detections.append(det)

    return detections, rejected_detections, time.time() - t_start, qwen_candidates


# ---------------------------------------------------------------------------
# main()
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="YOLO11-seg + Qwen3-VL-Flash Perception (qwen_first / yolo_first)")
    parser.add_argument("--image",   required=True, help="Path to input image")
    parser.add_argument("--model",   required=True, help="Path to YOLO11-seg model (.pt)")
    parser.add_argument("--conf",    type=float, default=0.15,
                        help="YOLO confidence threshold")
    parser.add_argument("--min-area-ratio", type=float, default=0.0005,
                        help="Min bbox area / image area")
    parser.add_argument("--max-area-ratio", type=float, default=0.60,
                        help="Max bbox area / image area")
    parser.add_argument("--pipeline", default="qwen_first",
                        choices=["yolo_first", "qwen_first", "hybrid"],
                        help="Perception pipeline (default: qwen_first)")
    parser.add_argument("--roi-expand", type=float, default=2.0,
                        help="Expand ratio for Qwen bbox -> ROI crop")
    parser.add_argument("--qwen-coarse-conf", type=float, default=0.55,
                        help="Min Qwen coarse confidence")
    parser.add_argument("--qwen-verify-conf", type=float, default=0.50,
                        help="Min Qwen verify confidence")
    parser.add_argument("--allow-unknown", action="store_true", default=False,
                        help="Allow unknown garbage_category in final detections")
    parser.add_argument("--save-vis", action="store_true",
                        help="Save overlay visualization")
    args = parser.parse_args()

    if args.pipeline == "hybrid":
        args.pipeline = "qwen_first"

    image_path = Path(args.image).expanduser().resolve()
    model_path = Path(args.model).expanduser().resolve()

    if not image_path.exists():
        print(f"[ERROR] Image not found: {image_path}")
        sys.exit(1)
    if not model_path.exists():
        print(f"[ERROR] Model not found: {model_path}")
        sys.exit(1)

    print(f"[START] pipeline={args.pipeline} | model={model_path.name}"
          f" | image={image_path.name}")

    img = cv2.imread(str(image_path))
    if img is None:
        print(f"[ERROR] Cannot read image: {image_path}")
        sys.exit(1)
    orig_h, orig_w = img.shape[:2]

    model = YOLO(str(model_path))
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    qwen_candidates_for_vis = []

    if args.pipeline == "yolo_first":
        crop_dir = ROOT / "data" / "crops" / "qwen" / timestamp
        crop_dir.mkdir(parents=True, exist_ok=True)
        detections, rejected_detections, infer_sec = run_yolo_first(
            image_path, model, args, img, orig_w, orig_h, crop_dir)

        summary = {
            "mode":            "YOLO11_SEG_QWEN_PERCEPTION",
            "backend":         "yolo11_seg_qwen",
            "pipeline":        "yolo_first",
            "model":           str(model_path),
            "qwen_model":      os.environ.get("QWEN_MODEL", "qwen3-vl-flash"),
            "image":           str(image_path),
            "source_image":    str(image_path),
            "image_width":     int(orig_w),
            "image_height":    int(orig_h),
            "created_timestamp": time.time(),
            "inference_sec":   round(infer_sec, 4),
            "num_detections":  len(detections),
            "detections":      detections,
            "rejected_detections": rejected_detections,
        }

    else:  # qwen_first (default)
        _get_qwen_config()  # set QWEN_MOCK_MODE early
        detections, rejected_detections, infer_sec, qwen_candidates_for_vis = \
            run_qwen_first(image_path, model, args, img, orig_w, orig_h, timestamp)

        summary = {
            "mode":              "YOLO11_QWEN_FIRST_ROI_PERCEPTION",
            "backend":           "qwen_first_yolo11_roi",
            "pipeline":          "qwen_first",
            "model":             str(model_path),
            "qwen_model":        os.environ.get("QWEN_MODEL", "qwen3-vl-flash"),
            "image":             str(image_path),
            "source_image":      str(image_path),
            "image_width":       int(orig_w),
            "image_height":      int(orig_h),
            "created_timestamp": time.time(),
            "inference_sec":     round(infer_sec, 4),
            "num_qwen_candidates": len(qwen_candidates_for_vis),
            "num_detections":    len(detections),
            "detections":        detections,
            "rejected_detections": rejected_detections,
        }

    save_json_atomic(DEFAULT_OUTPUT_JSON, summary)
    print(f"[SAVED] JSON -> {DEFAULT_OUTPUT_JSON}")
    print(f"[RESULT] {len(detections)} detections, "
          f"{len(rejected_detections)} rejected")

    if args.save_vis:
        if args.pipeline == "yolo_first":
            draw_overlay_qwen(image_path, detections, DEFAULT_OVERLAY)
        else:
            draw_overlay_qwen_first(
                image_path, detections, rejected_detections,
                qwen_candidates_for_vis, DEFAULT_OVERLAY)
        print(f"[SAVED] Overlay -> {DEFAULT_OVERLAY}")

    print(json.dumps(summary, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()

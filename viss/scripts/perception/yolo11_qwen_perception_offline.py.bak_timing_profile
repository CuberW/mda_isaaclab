def check_planner_ready(detections: list) -> bool:
    if not detections:
        return False
    required_keys = [
        "raw_class_name", "garbage_category", "target_bin",
        "confidence", "bbox_xyxy", "centroid_px",
        "bottom_contact_px", "bbox_area_ratio", "polygon"
    ]
    for det in detections:
        if det.get("approach_required") is True:
            return False
        for k in required_keys:
            if det.get(k) is None:
                return False
        bbox = det["bbox_xyxy"]
        if not isinstance(bbox, list) or len(bbox) != 4:
            return False
        centroid = det["centroid_px"]
        if not isinstance(centroid, list) or len(centroid) != 2:
            return False
        b_contact = det["bottom_contact_px"]
        if not isinstance(b_contact, list) or len(b_contact) != 2:
            return False
        poly = det["polygon"]
        if not isinstance(poly, list) or len(poly) < 3:
            return False
        try:
            conf = float(det["confidence"])
            if conf <= 0.0:
                return False
        except Exception:
            return False
        if det["target_bin"] == "unknown":
            return False
        if det["garbage_category"] == "unknown":
            return False
    return True


def save_json_atomic(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
    for i in range(50):
        try:
            tmp.replace(path)
            return
        except (PermissionError, OSError) as e:
            if i == 49:
                print(f"[ERROR] Failed to save {path} after 50 retries: {repr(e)}")
                raise
            time.sleep(0.02)


def encode_image_base64(image_path: Path) -> str:
    with open(image_path, "rb") as fh:
        return base64.b64encode(fh.read()).decode("utf-8")


def polygon_centroid(poly) -> list:
    if poly is None or len(poly) < 3:
        return None
    pts = np.array(poly, dtype=np.float32)
    m = cv2.moments(pts)
    if abs(m["m00"]) < 1e-6:
        return None
    cx = float(m["m10"] / m["m00"])
    cy = float(m["m01"] / m["m00"])
    return [round(cx, 2), round(cy, 2)]


def compute_bottom_contact(polygon: list, bbox_xyxy: list) -> list:
    """Compute the bottom-contact pixel from mask polygon (original-image coords)."""
    x1, y1, x2, y2 = bbox_xyxy
    if not polygon or len(polygon) < 3:
        return [round(float((x1 + x2) / 2.0), 3), round(float(y2), 3)]
    pts = np.array(polygon, dtype=np.float32)
    y_coords = pts[:, 1]
    y_max = float(np.max(y_coords))
    bbox_h = y2 - y1
    threshold = y_max - 0.08 * bbox_h
    bottom_pts = pts[y_coords >= threshold]
    if len(bottom_pts) == 0:
        return [round(float((x1 + x2) / 2.0), 3), round(float(y2), 3)]
    bottom_x = float(np.mean(bottom_pts[:, 0]))
    bottom_y = float(np.mean(bottom_pts[:, 1]))
    return [round(bottom_x, 3), round(bottom_y, 3)]


def clamp(v, lo, hi):
    return max(lo, min(hi, v))



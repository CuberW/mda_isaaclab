def run_qwen_first(image_path: Path, model, args,
                   img: np.ndarray, orig_w: int, orig_h: int,
                   timestamp: str):
    """
    Qwen-first pipeline.
    Returns (detections, rejected_detections, total_sec, qwen_candidates,
             fallback_meta: dict).
    fallback_meta keys: fallback_used (bool), fallback_reason (str),
                        executed_pipeline (str).
    """
    t_start = time.time()
    image_area = orig_w * orig_h

    roi_dir = ROOT / "data" / "crops" / "qwen_roi" / timestamp
    roi_dir.mkdir(parents=True, exist_ok=True)

    provisional_detections = []
    rejected_detections = []

    # Step 1: Qwen coarse locate
    t_coarse_start = time.time()
    qwen_candidates = coarse_locate_trash_with_qwen(image_path, orig_w, orig_h)
    qwen_coarse_sec = time.time() - t_coarse_start

    # Sort candidates: key: (confidence, pixel_area) descending
    def cand_sort_key(c):
        x1, y1, x2, y2 = c["bbox_xyxy"]
        area = (x2 - x1) * (y2 - y1)
        return (c["confidence"], area)
    qwen_candidates = sorted(qwen_candidates, key=cand_sort_key, reverse=True)

    # Truncate candidates if max_qwen_candidates is specified
    if args.max_qwen_candidates is not None and len(qwen_candidates) > args.max_qwen_candidates:
        truncated_cands = qwen_candidates[args.max_qwen_candidates:]
        for tc in truncated_cands:
            rejected_detections.append({
                "raw_class_name":  tc["object_name"],
                "bbox_xyxy":       tc["bbox_xyxy"],
                "qwen_bbox_xyxy":  tc["bbox_xyxy"],
                "reject_reason":   "max_qwen_candidates_limit",
                "candidate_id":    tc["candidate_id"],
            })
        qwen_candidates = qwen_candidates[:args.max_qwen_candidates]

    if not qwen_candidates:
        if QWEN_MOCK_MODE:
            print("[QWEN MOCK] qwen_first requires API, fallback to yolo_first")
            crop_dir = ROOT / "data" / "crops" / "qwen" / timestamp
            crop_dir.mkdir(parents=True, exist_ok=True)
            dets, rejects, yolo_sec = run_yolo_first(
                image_path, model, args, img, orig_w, orig_h, crop_dir)
            fb_meta = {"fallback_used": True,
                       "fallback_reason": "missing_qwen_api",
                       "executed_pipeline": "yolo_first"}
            return dets, rejects, time.time() - t_start, [], fb_meta
        else:
            print("[QWEN FIRST] No candidates from Qwen")
            fb_meta = {"fallback_used": False,
                       "fallback_reason": "none",
                       "executed_pipeline": "qwen_first"}
            return [], [], time.time() - t_start, [], fb_meta

    yolo_roi_total_sec = 0.0
    yolo_roi_calls = 0
    refined_count = 0

    for candidate in qwen_candidates:
        cid              = candidate["candidate_id"]
        qwen_coarse_conf = candidate["confidence"]
        is_graspable     = candidate["is_graspable_trash"]

        if not is_graspable:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":  candidate["bbox_xyxy"],
                "reject_reason":   "qwen_coarse_not_graspable",
                "candidate_id":    cid,
            })
            continue

        if qwen_coarse_conf < args.qwen_coarse_conf:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":  candidate["bbox_xyxy"],
                "reject_reason":   f"qwen_coarse_conf_too_low({qwen_coarse_conf:.2f})",
                "candidate_id":    cid,
            })
            continue

        bx1, by1, bx2, by2 = candidate["bbox_xyxy"]
        if bx2 <= bx1 or by2 <= by1:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "reject_reason":   "invalid_qwen_bbox",
                "candidate_id":    cid,
            })
            continue

        # Check max_roi_refine limit
        if args.max_roi_refine is not None and refined_count >= args.max_roi_refine:
            rejected_detections.append({
                "raw_class_name":  candidate["object_name"],
                "bbox_xyxy":       candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":  candidate["bbox_xyxy"],
                "reject_reason":   "max_roi_refine_limit",
                "candidate_id":    cid,
            })
            continue

        refined_count += 1

        # Step 2: YOLO ROI refine
        t_yolo_start = time.time()
        yolo_result = refine_trash_with_yolo_roi(
            image=img, img_w=orig_w, img_h=orig_h,
            qwen_candidate=candidate,
            model=model,
            roi_expand=args.roi_expand,
            conf_thresh=args.conf,
            min_area_ratio=args.min_area_ratio,
            roi_save_dir=roi_dir,
        )
        yolo_roi_total_sec += time.time() - t_yolo_start
        yolo_roi_calls += 1

        if not yolo_result["success"]:
            rejected_detections.append({
                "raw_class_name":     candidate["object_name"],
                "bbox_xyxy":          candidate["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      yolo_result.get("reason", "failed_yolo_refine"),
                "candidate_id":       cid,
            })
            continue

        if yolo_result["bbox_area_ratio"] < args.min_area_ratio:
            rejected_detections.append({
                "raw_class_name":     yolo_result["raw_class_name"],
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      f"yolo_area_too_small({yolo_result['bbox_area_ratio']:.6f})",
                "candidate_id":       cid,
            })
            continue

        if yolo_result["bbox_area_ratio"] > args.max_area_ratio:
            rejected_detections.append({
                "raw_class_name":     yolo_result["raw_class_name"],
                "bbox_xyxy":          yolo_result["bbox_xyxy"],
                "qwen_bbox_xyxy":     candidate["bbox_xyxy"],
                "roi_crop_bbox_xyxy": yolo_result.get("crop_bbox"),
                "reject_reason":      f"yolo_area_too_large({yolo_result['bbox_area_ratio']:.3f})",
                "candidate_id":       cid,
            })
            continue

        final_crop_path = Path(yolo_result.get("final_crop_path",
                                               yolo_result["crop_path"]))
        raw_class_name  = yolo_result["raw_class_name"]
        
        det_id = len(provisional_detections) + 1
        obj_id = f"qwen_yolo_det_{det_id:03d}"

        # Build provisional detection

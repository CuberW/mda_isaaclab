def normalize_qwen_bbox_norm(candidate: dict, image_width: int, image_height: int) -> tuple:
    """
    Parse candidate coordinates with priority to bbox_norm_xyxy.
    Returns (success: bool, reason: str, parsed_coords: dict, is_fallback: bool).
    """
    cid = candidate.get("candidate_id", "unknown")
    bbox_norm = candidate.get("bbox_norm_xyxy")
    is_fallback = False

    if bbox_norm is not None:
        if not isinstance(bbox_norm, list) or len(bbox_norm) != 4:
            return False, "invalid_qwen_bbox_norm", {}, False
        try:
            x1_norm, y1_norm, x2_norm, y2_norm = [float(v) for v in bbox_norm]
        except Exception:
            return False, "invalid_qwen_bbox_norm", {}, False

        x1_norm = clamp(x1_norm, 0.0, 1.0)
        y1_norm = clamp(y1_norm, 0.0, 1.0)
        x2_norm = clamp(x2_norm, 0.0, 1.0)
        y2_norm = clamp(y2_norm, 0.0, 1.0)

        if x2_norm <= x1_norm or y2_norm <= y1_norm:
            # Try sorting once
            x1_norm, x2_norm = sorted([x1_norm, x2_norm])
            y1_norm, y2_norm = sorted([y1_norm, y2_norm])
            if x2_norm <= x1_norm or y2_norm <= y1_norm:
                return False, "invalid_qwen_bbox_norm", {}, False
    else:
        # Fallback to legacy bbox_xyxy
        bbox_legacy = candidate.get("bbox_xyxy")
        if bbox_legacy is None:
            return False, "missing_bbox_fields", {}, False
        if not isinstance(bbox_legacy, list) or len(bbox_legacy) != 4:
            return False, "legacy_invalid_bbox_xyxy", {}, True
        try:
            bx1, by1, bx2, by2 = [float(v) for v in bbox_legacy]
        except Exception:
            return False, "legacy_invalid_bbox_xyxy", {}, True

        is_fallback = True
        scale_x = 1.0
        scale_y = 1.0

        if all(0.0 <= v <= 1.05 for v in [bx1, by1, bx2, by2]) and max(bx1, by1, bx2, by2) <= 1.05:
            # Normalized 0~1
            x1_norm, y1_norm, x2_norm, y2_norm = bx1, by1, bx2, by2
        elif all(0.0 <= v <= 100.0 for v in [bx1, by1, bx2, by2]) and max(bx1, by1, bx2, by2) <= 100.0:
            # Percentage 0~100
            x1_norm = bx1 / 100.0
            y1_norm = by1 / 100.0
            x2_norm = bx2 / 100.0
            y2_norm = by2 / 100.0
        elif all(0.0 <= v <= 1000.0 for v in [bx1, by1, bx2, by2]) and (bx2 > image_width or by2 > image_height or max(bx1, by1, bx2, by2) > max(image_width, image_height) * 1.1):
            # 0~1000 scale
            scale_x = 1.0 / 1000.0
            scale_y = 1.0 / 1000.0
            x1_norm = bx1 * scale_x
            y1_norm = by1 * scale_y
            x2_norm = bx2 * scale_x
            y2_norm = by2 * scale_y
        else:
            # Pixel coordinates
            scale_x = 1.0 / image_width
            scale_y = 1.0 / image_height
            x1_norm = bx1 * scale_x
            y1_norm = by1 * scale_y
            x2_norm = bx2 * scale_x
            y2_norm = by2 * scale_y

        x1_norm = clamp(x1_norm, 0.0, 1.0)
        y1_norm = clamp(y1_norm, 0.0, 1.0)
        x2_norm = clamp(x2_norm, 0.0, 1.0)
        y2_norm = clamp(y2_norm, 0.0, 1.0)

        if x2_norm <= x1_norm or y2_norm <= y1_norm:
            x1_norm, x2_norm = sorted([x1_norm, x2_norm])
            y1_norm, y2_norm = sorted([y1_norm, y2_norm])
            if x2_norm <= x1_norm or y2_norm <= y1_norm:
                return False, "legacy_invalid_bbox_xyxy", {}, True

    # 3. Convert normalized coordinates to original pixel coordinates
    x1_px = round(x1_norm * image_width)
    y1_px = round(y1_norm * image_height)
    x2_px = round(x2_norm * image_width)
    y2_px = round(y2_norm * image_height)

    # 4. Clamp pixel coordinates to image bounds
    x1_px = clamp(x1_px, 0, image_width - 1)
    x2_px = clamp(x2_px, 0, image_width - 1)
    y1_px = clamp(y1_px, 0, image_height - 1)
    y2_px = clamp(y2_px, 0, image_height - 1)

    # 5. Check bbox validity
    w_px = x2_px - x1_px
    h_px = y2_px - y1_px
    area_ratio = (w_px * h_px) / float(image_width * image_height)

    if w_px < 5:
        return False, "width_too_small", {}, is_fallback
    if h_px < 5:
        return False, "height_too_small", {}, is_fallback
    if area_ratio < 0.0001:
        return False, "area_ratio_too_small", {}, is_fallback
    if area_ratio > 0.9:
        return False, "area_ratio_too_large", {}, is_fallback

    # Parse center
    center_norm = candidate.get("center_norm")
    center_px_legacy = candidate.get("center_px")

    parsed_center_norm = None
    if isinstance(center_norm, list) and len(center_norm) == 2:
        try:
            cx_n = clamp(float(center_norm[0]), 0.0, 1.0)
            cy_n = clamp(float(center_norm[1]), 0.0, 1.0)
            parsed_center_norm = [cx_n, cy_n]
        except Exception:
            pass

    if parsed_center_norm is None and isinstance(center_px_legacy, list) and len(center_px_legacy) == 2:
        try:
            cx_px = float(center_px_legacy[0])
            cy_px = float(center_px_legacy[1])
            if is_fallback and 'scale_x' in locals() and 'scale_y' in locals():
                cx_n = clamp(cx_px * scale_x, 0.0, 1.0)
                cy_n = clamp(cy_px * scale_y, 0.0, 1.0)
            else:
                cx_n = clamp(cx_px / image_width, 0.0, 1.0)
                cy_n = clamp(cy_px / image_height, 0.0, 1.0)
            parsed_center_norm = [cx_n, cy_n]
        except Exception:
            pass

    if parsed_center_norm is None:
        parsed_center_norm = [
            (x1_norm + x2_norm) / 2.0,
            (y1_norm + y2_norm) / 2.0
        ]

    u_px = clamp(round(parsed_center_norm[0] * image_width), 0, image_width - 1)
    v_px = clamp(round(parsed_center_norm[1] * image_height), 0, image_height - 1)

    result_dict = {
        "bbox_norm_xyxy": [round(x1_norm, 5), round(y1_norm, 5), round(x2_norm, 5), round(y2_norm, 5)],
        "center_norm":    [round(parsed_center_norm[0], 5), round(parsed_center_norm[1], 5)],
        "bbox_xyxy":      [x1_px, y1_px, x2_px, y2_px],
        "center_px":      [u_px, v_px]
    }

    return True, "success", result_dict, is_fallback


def coarse_locate_trash_with_qwen(image_path: Path, img_w: int, img_h: int) -> list:
    """
    Send the full image to Qwen3-VL-Flash for coarse trash localization.
    Returns list of candidate dicts (bbox in original-image coords).
    Empty list on failure or mock mode.
    """
    api_key, base_url, model_name = _get_qwen_config()

    if QWEN_MOCK_MODE:
        return []

    prompt = (
        "你是机器人垃圾分类系统的视觉粗定位模块。\n"
        "请在整张图中寻找“可被机器人抓取并投放的垃圾物体”。\n"
        "只允许识别真正的垃圾或疑似垃圾。不要把以下对象识别为垃圾：\n"
        "* 机器人机械臂\n* 机器人夹爪\n* 桌子\n* 地面\n* 墙面\n"
        "* 阴影\n* 垃圾桶\n* 垃圾桶边缘\n* 传感器、支架、线缆\n"
        "* 任何明显不是垃圾的背景物体\n\n"
        "请输出归一化比例坐标，不要输出像素坐标。\n\n"
        "请输出严格 JSON，不要输出解释性文字。\n\n"
        "输出格式：\n"
        "{\n"
        '  "candidates": [\n'
        "    {\n"
        '      "candidate_id": "vlm_candidate_001",\n'
        '      "object_name": "...",\n'
        '      "is_graspable_trash": true,\n'
        '      "garbage_category_guess": "recyclable|kitchen|hazardous|other|unknown",\n'
        '      "bbox_norm_xyxy": [0.0, 0.0, 1.0, 1.0],\n'
        '      "center_norm": [0.5, 0.5],\n'
        '      "confidence": 0.0,\n'
        '      "reason": "..."\n'
        "    }\n"
        "  ]\n"
        "}\n\n"
        "要求：\n"
        "- bbox_norm_xyxy 是相对整张输入图的比例坐标。\n"
        "- x1_norm、x2_norm 表示相对图像宽度的比例。\n"
        "- y1_norm、y2_norm 表示相对图像高度的比例。\n"
        "- 所有坐标必须在 0.0 到 1.0 之间。\n"
        "- x1_norm < x2_norm。\n"
        "- y1_norm < y2_norm。\n"
        "- 不要输出像素坐标。\n"
        "- 不要输出 640 坐标。\n"
        "- 不要输出 1000 坐标。\n"
        "- 不要输出百分比 0 到 100。\n"
        "- 不要输出中心点宽高格式。\n"
        "- 只输出严格 JSON。"
    )

    raw_text = _post_qwen(base_url, api_key, model_name, prompt, image_path)
    if not raw_text:
        return []

    _append_qwen_raw_log("COARSE", raw_text)

    try:
        cleaned = _extract_json_from_text(raw_text)
        parsed = json.loads(cleaned)
    except Exception as e:
        print(f"[QWEN COARSE PARSE ERROR] {repr(e)}\nRaw:\n{raw_text[:500]}")
        return []

    raw_candidates = parsed.get("candidates", [])
    if not isinstance(raw_candidates, list):
        return []

    valid = []
    for idx, c in enumerate(raw_candidates):
        cid = c.get("candidate_id", f"vlm_candidate_{idx+1:03d}")
        obj_name = c.get("object_name", "unknown_object")
        is_graspable = c.get("is_graspable_trash", False)
        if not isinstance(is_graspable, bool):
            is_graspable = bool(is_graspable)
        cat_guess = c.get("garbage_category_guess", "unknown").lower().strip()
        if cat_guess not in ALLOWED_CATEGORIES:
            cat_guess = "unknown"
        conf = c.get("confidence", 0.0)
        try:
            conf = float(conf)
        except Exception:
            conf = 0.0
        reason = c.get("reason", "")

        success, err_reason, coords, is_fb = normalize_qwen_bbox_norm(c, img_w, img_h)
        if not success:
            raw_val = c.get("bbox_norm_xyxy") if c.get("bbox_norm_xyxy") is not None else c.get("bbox_xyxy")
            print(f"[QWEN NORM BBOX] id={cid} raw={raw_val} valid=false reason={err_reason}")
            continue

        if is_fb:
            print(f"[QWEN BBOX FALLBACK] using legacy bbox_xyxy field")
            print(f"[QWEN BBOX FALLBACK] id={cid} raw_bbox_xyxy={c.get('bbox_xyxy')} px={coords['bbox_xyxy']} reason=legacy_bbox_xyxy")
        else:
            print(f"[QWEN NORM BBOX] id={cid} norm={coords['bbox_norm_xyxy']} px={coords['bbox_xyxy']} image={img_w}x{img_h} valid=true")

        valid.append({
            "candidate_id":           cid,
            "object_name":            obj_name,
            "is_graspable_trash":     is_graspable,
            "garbage_category_guess": cat_guess,
            "bbox_norm_xyxy":         coords["bbox_norm_xyxy"],
            "center_norm":            coords["center_norm"],
            "bbox_xyxy":              coords["bbox_xyxy"],
            "center_px":              coords["center_px"],
            "confidence":             conf,
            "reason":                 reason,
        })

    print(f"[QWEN COARSE] {len(valid)}/{len(raw_candidates)} valid candidates")
    return valid



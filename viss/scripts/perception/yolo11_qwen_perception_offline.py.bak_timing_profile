def postprocess_detections_dedup(detections: list, rejected_detections: list) -> list:
    """
    Deduplicate detections based on final YOLO segmentation bboxes and centroids.
    Rejected duplicates are added to rejected_detections.
    Returns the list of kept detections.
    """
    if not detections:
        return []

    # Sort detections by priority (best first)
    def sort_key(d):
        app_req = 1 if d.get("approach_required", True) else 0
        conf = d.get("confidence", 0.0)
        yolo_conf = d.get("yolo_confidence", 0.0)
        area_ratio = d.get("bbox_area_ratio", 0.0)
        try:
            det_num = int(d["object_id"].split("_")[-1])
        except Exception:
            det_num = 999
        return (app_req, -conf, -yolo_conf, -area_ratio, det_num)

    sorted_dets = sorted(detections, key=sort_key)
    kept_detections = []

    for d in sorted_dets:
        # Check duplicate against already kept detections
        is_dup = False
        dup_target = None
        best_iou = 0.0
        best_dist = None

        for k in kept_detections:
            # bbox IoU
            iou = bbox_iou(d["bbox_xyxy"], k["bbox_xyxy"])
            # centroid distance
            c1 = d["centroid_px"]
            c2 = k["centroid_px"]
            dist = ((c1[0] - c2[0])**2 + (c1[1] - c2[1])**2) ** 0.5
            # bottom contact distance
            b1 = d["bottom_contact_px"]
            b2 = k["bottom_contact_px"]
            b_dist = ((b1[0] - b2[0])**2 + (b1[1] - b2[1])**2) ** 0.5

            cond1 = iou >= 0.45
            cond2 = dist <= 20.0
            cond3 = b_dist <= 25.0 and iou >= 0.20

            if cond1 or cond2 or cond3:
                is_dup = True
                dup_target = k
                best_iou = iou
                best_dist = dist
                break

        if is_dup:
            # Append to rejected_detections
            rejected_detections.append({
                "candidate_id":          d["raw_object_id"],
                "object_id":             d["object_id"],
                "raw_class_name":        d["raw_class_name"],
                "bbox_xyxy":             d["bbox_xyxy"],
                "qwen_bbox_xyxy":        d["qwen_bbox_xyxy"],
                "reason":                "duplicate_after_yolo_refine",
                "reject_reason":         "duplicate_after_yolo_refine",
                "duplicate_of":          dup_target["object_id"],
                "duplicate_iou":         round(best_iou, 4),
                "duplicate_center_dist": round(best_dist, 2) if best_dist is not None else None,
                "original_detection":    d
            })
            # Add raw_object_id to kept detection's merger list
            if d["raw_object_id"] not in dup_target["merged_from_candidates"]:
                dup_target["merged_from_candidates"].append(d["raw_object_id"])
        else:
            d["merged_from_candidates"] = [d["raw_object_id"]]
            kept_detections.append(d)

    # Re-sort kept detections by object_id suffix to preserve clean sequence
    def id_key(d):
        try:
            return int(d["object_id"].split("_")[-1])
        except Exception:
            return 999
    return sorted(kept_detections, key=id_key)



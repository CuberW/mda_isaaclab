def run_yolo_first(image_path: Path, model, args,
                   img: np.ndarray, orig_w: int, orig_h: int,
                   crop_dir: Path):
    """
    Original YOLO-first pipeline.
    Returns (detections, rejected_detections, yolo_infer_sec).
    """
    image_area = orig_w * orig_h
    t0 = time.time()
    results = model.predict(source=str(image_path), conf=args.conf, verbose=False)
    yolo_infer_sec = time.time() - t0

    result = results[0]
    names  = result.names
    boxes  = result.boxes
    masks  = result.masks

    detections = []
    rejected_detections = []

    if boxes is None:
        return detections, rejected_detections, yolo_infer_sec

    for i, box in enumerate(boxes):
        cls_id         = int(box.cls[0].item())
        raw_class_name = names[cls_id]
        yolo_conf      = float(box.conf[0].item())

        xyxy = box.xyxy[0].detach().cpu().numpy().astype(float).tolist()
        x1, y1, x2, y2 = xyxy
        x1 = clamp(x1, 0, orig_w - 1)
        x2 = clamp(x2, 0, orig_w - 1)
        y1 = clamp(y1, 0, orig_h - 1)
        y2 = clamp(y2, 0, orig_h - 1)
        if x2 <= x1 or y2 <= y1:
            continue

        bbox_w = x2 - x1
        bbox_h = y2 - y1
        area_ratio = (bbox_w * bbox_h) / max(1.0, image_area)

        if area_ratio > args.max_area_ratio:
            print(f"[YOLO FIRST FILTER] area_ratio {area_ratio:.3f} > {args.max_area_ratio}")
            rejected_detections.append({
                "raw_class_name": raw_class_name,
                "bbox_xyxy":      [x1, y1, x2, y2],
                "reject_reason":  "area_ratio_too_large",
            })
            continue

        polygon  = []
        centroid = None
        if masks is not None and getattr(masks, "xy", None) is not None \
                and i < len(masks.xy):
            poly_np = masks.xy[i]
            for px, py in poly_np:
                polygon.append([round(float(px), 3), round(float(py), 3)])
            centroid = polygon_centroid(poly_np)

        if centroid is None:
            centroid = [round(float((x1+x2)/2.0), 3),
                        round(float((y1+y2)/2.0), 3)]

        bottom_contact_px = compute_bottom_contact(polygon, [x1, y1, x2, y2])

        pad_x = bbox_w * 0.15
        pad_y = bbox_h * 0.15
        c_x1 = max(0, int(x1 - pad_x))
        c_y1 = max(0, int(y1 - pad_y))
        c_x2 = min(orig_w, int(x2 + pad_x))
        c_y2 = min(orig_h, int(y2 + pad_y))
        crop_img  = img[c_y1:c_y2, c_x1:c_x2]
        det_id    = len(detections) + 1
        crop_path = crop_dir / f"det_{det_id:03d}_crop.jpg"
        cv2.imwrite(str(crop_path), crop_img)

        qwen_res        = call_qwen_api(crop_path, raw_class_name)
        garbage_category = qwen_res.get("garbage_category", "unknown")
        target_bin       = qwen_res.get("target_bin", "unknown")
        qwen_conf        = qwen_res.get("confidence", 0.5)

        if qwen_conf <= 0.0:
            combined_conf = round(yolo_conf * 0.8, 4)
        else:
            combined_conf = round(min(yolo_conf, qwen_conf), 4)

        approach_required, approach_reason = compute_approach_required(
            [x1, y1, x2, y2], qwen_conf, orig_w, orig_h)

        det = {
            "object_id":            f"yolo11_qwen_det_{det_id:03d}",
            "raw_class_name":       raw_class_name,
            "raw_object_id":        f"yolo_det_{det_id:03d}",
            "class_name":           "trash_object",
            "display_name":         "trash_object",
            "category":             "trash_object",
            "garbage_category":     garbage_category,
            "garbage_category_cn":  CATEGORY_CN.get(garbage_category, "\u672a\u77e5"),
            "target_bin":           target_bin,
            "target_bin_cn":        BIN_CN.get(target_bin, "unknown"),
            "confidence":           combined_conf,
            "yolo_confidence":      round(yolo_conf, 4),
            "qwen_confidence":      round(qwen_conf, 4),
            "bbox_xyxy":            [round(x1,3), round(y1,3), round(x2,3), round(y2,3)],
            "centroid_px":          centroid,
            "bottom_contact_px":    bottom_contact_px,
            "bbox_area_ratio":      round(area_ratio, 6),
            "polygon":              polygon,
            "crop_path":            str(crop_path),
            "approach_required":    approach_required,
            "approach_reason":      approach_reason,
            "qwen_result":          qwen_res,
            "qwen_verify_skipped":  False,
            "source":               "yolo11_seg_qwen",
        }
        detections.append(det)

from concurrent.futures import ThreadPoolExecutor, as_completed

def run_qwen_verify_batch(detections_to_verify: list, args) -> dict:
    """
    Run Qwen crop verification concurrently using ThreadPoolExecutor.
    Returns a dict mapping object_id -> qwen_verify_result.
    """
    results_map = {}
    if not detections_to_verify:
        return results_map

    max_workers = getattr(args, "qwen_verify_workers", 4)
    if max_workers < 1:
        max_workers = 1

    # Thread execution target
    def verify_single(det):
        final_crop_path = Path(det["crop_path"])
        raw_class_name = det["raw_class_name"]
        obj_id = det["object_id"]
        cid = det["raw_object_id"]
        try:
            res = classify_crop_with_qwen(
                final_crop_path, raw_class_name,
                object_id=obj_id, candidate_id=cid, attempt=1
            )
            # Control concurrency risk: retry once if API fails or returns unknown
            if not res or res.get("garbage_category") == "unknown":
                time.sleep(1.0)
                res = classify_crop_with_qwen(
                    final_crop_path, raw_class_name,
                    object_id=obj_id, candidate_id=cid, attempt=2
                )
            return obj_id, res
        except Exception as e:
            fallback_res = {
                "object_name": raw_class_name,
                "garbage_category": "unknown",
                "target_bin": "unknown",
                "confidence": 0.0,
                "is_graspable_trash": False,
                "reason": f"qwen_verify_exception: {repr(e)}"
            }
            return obj_id, fallback_res

    # Use ThreadPoolExecutor to run concurrently
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        future_to_det = {executor.submit(verify_single, det): det for det in detections_to_verify}
        for future in as_completed(future_to_det):
            det = future_to_det[future]
            try:
                obj_id, res = future.result()
                results_map[obj_id] = res
            except Exception as e:
                obj_id = det["object_id"]
                raw_class_name = det["raw_class_name"]
                fallback_res = {
                    "object_name": raw_class_name,
                    "garbage_category": "unknown",
                    "target_bin": "unknown",
                    "confidence": 0.0,
                    "is_graspable_trash": False,
                    "reason": f"qwen_verify_exception: {repr(e)}"
                }
                results_map[obj_id] = fallback_res

    return results_map



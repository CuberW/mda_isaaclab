def _mock_qwen_classify(raw_class: str) -> dict:
    mapped = RAW_CLASS_MOCK_MAP.get(raw_class, ("unknown", "unknown"))
    cat, target_bin = mapped
    return {
        "object_name":       raw_class,
        "garbage_category":  cat,
        "target_bin":        target_bin,
        "confidence":        0.85,
        "is_graspable_trash": True,
        "reason":            "Mocked fallback mapping based on YOLO class name",
    }


def _parse_classify_response(text: str, raw_class: str) -> dict:
    try:
        cleaned = _extract_json_from_text(text)
        parsed = json.loads(cleaned)
    except Exception as e:
        print(f"[QWEN CLASSIFY PARSE ERROR] {repr(e)}")
        return _mock_qwen_classify(raw_class)

    garbage_category = parsed.get("garbage_category", "unknown").lower().strip()
    if garbage_category not in ALLOWED_CATEGORIES:
        garbage_category = "unknown"
    target_bin = parsed.get("target_bin", "unknown").strip()
    if target_bin not in ALLOWED_BINS:
        target_bin = CATEGORY_TO_BIN.get(garbage_category, "unknown")
    if target_bin == "unknown" and garbage_category != "unknown":
        target_bin = CATEGORY_TO_BIN.get(garbage_category, "unknown")

    conf = parsed.get("confidence", 0.5)
    try:
        conf = float(conf)
    except Exception:
        conf = 0.0

    is_graspable = parsed.get("is_graspable_trash", True)
    if not isinstance(is_graspable, bool):
        is_graspable = True

    return {
        "object_name":       parsed.get("object_name", raw_class),
        "garbage_category":  garbage_category,
        "target_bin":        target_bin,
        "confidence":        conf,
        "is_graspable_trash": is_graspable,
        "reason":            parsed.get("reason", "Qwen classify parsed"),
    }


def classify_crop_with_qwen(crop_path: Path, raw_class: str = "trash_object",
                             det_label: str = "", object_id: str = "",
                             candidate_id: str = "", attempt: int = 1) -> dict:
    """Send YOLO crop to Qwen for final category verification."""
    api_key, base_url, model_name = _get_qwen_config()
    if QWEN_MOCK_MODE:
        return _mock_qwen_classify(raw_class)

    prompt = (
        "你是机器人垃圾分类系统的视觉分类模块。\n"
        "请根据输入图片中的单个垃圾物体，判断它属于哪一类垃圾。\n"
        "只允许输出严格 JSON，不要输出解释性文字。\n\n"
        "垃圾类别只能从以下五类中选择：\n"
        "1. recyclable：可回收垃圾\n"
        "2. kitchen：厨余垃圾\n"
        "3. hazardous：有害垃圾\n"
        "4. other：其他垃圾\n"
        "5. unknown：无法判断\n\n"
        "target_bin 只能从以下五个值中选择：\n"
        "* bin_recyclable_blue\n* bin_kitchen_green\n"
        "* bin_hazardous_red\n* bin_other_gray\n* unknown\n\n"
        "输出格式：\n"
        "{\n"
        "  \"object_name\": \"...\",\n"
        "  \"garbage_category\": \"...\",\n"
        "  \"target_bin\": \"...\",\n"
        "  \"confidence\": 0.0,\n"
        "  \"is_graspable_trash\": true,\n"
        "  \"reason\": \"...\"\n"
        "}\n\n"
        "要求：\n"
        "- 只看图中主体垃圾，不要判断背景。\n"
        "- 如果看不清，garbage_category 输出 unknown。\n"
        "- 如果不是垃圾，is_graspable_trash 输出 false。\n"
        "- confidence 范围为 0 到 1。\n"
        "- 只输出 JSON。"
    )

    raw_text = _post_qwen(base_url, api_key, model_name, prompt, crop_path)
    tag_parts = []
    if object_id:
        tag_parts.append(f"object_id={object_id}")
    if candidate_id:
        tag_parts.append(f"candidate={candidate_id}")
    tag_parts.append(f"attempt={attempt}")
    tag = f"VERIFY {' '.join(tag_parts)}"

    if not raw_text:
        _append_qwen_raw_log(tag, "[MOCKED RESPONSE] Qwen API call failed.")
        return _mock_qwen_classify(raw_class)

    _append_qwen_raw_log(tag, raw_text)
    return _parse_classify_response(raw_text, raw_class)



def draw_overlay_qwen_first(image_path: Path, detections: list,
                             rejected: list, qwen_candidates: list,
                             overlay_path: Path, approach_candidates: list = None,
                             vis_mode: str = "planner") -> None:
    img = cv2.imread(str(image_path))
    if img is None:
        return
    img_h, img_w = img.shape[:2]
    overlay = img.copy()

    def get_suffix(s: str) -> str:
        m = re.findall(r'\d+', s)
        return m[-1] if m else "000"

    if approach_candidates is None:
        approach_candidates = []

    if vis_mode == "debug":
        # 1. Draw Qwen coarse bboxes (VLM_NORM)
        for c in qwen_candidates:
            bx = [int(round(v)) for v in c["bbox_xyxy"]]
            cv2.rectangle(overlay, (bx[0], bx[1]), (bx[2], bx[3]), (0, 200, 255), 1)
            
            suffix = get_suffix(c["candidate_id"])
            cat = c.get("garbage_category_guess", "unknown")
            conf = c.get("confidence", 0.0)
            label = f"VLM_NORM {suffix} {cat} {conf:.2f}"
            
            font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.45, 1
            (tw, th), bl = cv2.getTextSize(label, font, fscale, thick)
            
            ly = bx[1] - 5
            if ly - th - 2 < 0:
                ly = bx[3] + th + 5
                
            cv2.rectangle(overlay, (bx[0], ly - th - 2), (bx[0] + tw + 4, ly + bl), (0, 100, 128), -1)
            cv2.putText(overlay, label, (bx[0] + 2, ly - 2), font, fscale, (255, 255, 255), thick, cv2.LINE_AA)

        # 2. Draw Rejected Candidates (thin gray line, and reject count / short label)
        for r in rejected:
            bbox = r.get("bbox_xyxy") or r.get("roi_crop_bbox_xyxy") or r.get("qwen_bbox_xyxy")
            if bbox:
                bx = [int(round(v)) for v in bbox]
                cv2.rectangle(overlay, (bx[0], bx[1]), (bx[2], bx[3]), (100, 100, 100), 1)
                
                reason = r.get("reject_reason", r.get("reason", "rejected"))
                label = f"REJECT {reason}"
                
                font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.35, 1
                (tw, th), bl = cv2.getTextSize(label, font, fscale, thick)
                
                ly = bx[1] - 5
                if ly - th - 2 < 0:
                    ly = bx[3] + th + 5
                
                cv2.rectangle(overlay, (bx[0], ly - th - 2), (bx[0] + tw + 4, ly + bl), (60, 60, 60), -1)
                cv2.putText(overlay, label, (bx[0] + 2, ly - 2), font, fscale, (200, 200, 200), thick, cv2.LINE_AA)

    # 3. Draw Mask Fill for detections
    mask_dets = detections if vis_mode == "planner" else (detections + approach_candidates)
    mask_layer = overlay.copy()
    for det in mask_dets:
        cat   = det.get("garbage_category", "unknown")
        color = CATEGORY_COLOR.get(cat, CATEGORY_COLOR["unknown"])
        poly  = det.get("polygon")
        if poly and len(poly) >= 3:
            pts = np.array(poly, dtype=np.int32).reshape((-1, 1, 2))
            cv2.fillPoly(mask_layer, [pts], color)
    overlay = cv2.addWeighted(mask_layer, 0.28, overlay, 0.72, 0)

    # 4. Draw Kept Detections
    target_dets = detections if vis_mode == "planner" else (detections + approach_candidates)
    for det in target_dets:
        cat   = det.get("garbage_category", "unknown")
        color = CATEGORY_COLOR.get(cat, CATEGORY_COLOR["unknown"])
        x1, y1, x2, y2 = [int(round(v)) for v in det["bbox_xyxy"]]

        # ROI Crop Bbox
        if vis_mode == "debug":
            roi_bbox = det.get("roi_crop_bbox_xyxy")
            if roi_bbox:
                rx = [int(round(v)) for v in roi_bbox]
                cv2.rectangle(overlay, (rx[0], rx[1]), (rx[2], rx[3]), (255, 200, 0), 1)
                
                suffix_roi = get_suffix(det["raw_object_id"])
                label_roi = f"ROI {suffix_roi}"
                font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.4, 1
                (tw, th), bl = cv2.getTextSize(label_roi, font, fscale, thick)
                ly = rx[1] - 5
                if ly - th - 2 < 0:
                    ly = rx[3] + th + 5
                cv2.rectangle(overlay, (rx[0], ly - th - 2), (rx[0] + tw + 4, ly + bl), (128, 100, 0), -1)
                cv2.putText(overlay, label_roi, (rx[0] + 2, ly - 2), font, fscale, (255, 255, 255), thick, cv2.LINE_AA)

        # YOLO Box
        cv2.rectangle(overlay, (x1, y1), (x2, y2), color, 2)
        
        # Polygon Boundaries
        poly = det.get("polygon")
        if poly and len(poly) >= 3:
            pts = np.array(poly, dtype=np.int32).reshape((-1, 1, 2))
            cv2.polylines(overlay, [pts], isClosed=True, color=color, thickness=2)

        # Centroid & Bottom Contact Points
        if vis_mode == "debug":
            c_px = det.get("centroid_px")
            if c_px:
                cv2.circle(overlay, (int(c_px[0]), int(c_px[1])), 3, (255, 255, 0), -1)
        b_px = det.get("bottom_contact_px")
        if b_px:
            cv2.circle(overlay, (int(b_px[0]), int(b_px[1])), 4, (0, 0, 255), -1)

        # YOLO Label with Overlap Check
        suffix = get_suffix(det["object_id"])
        
        if vis_mode == "planner":
            conf = det.get("confidence", 0.0)
            label = f"D{suffix} {cat} {conf:.2f}"
        else:
            has_overlap = False
            for other in detections + approach_candidates:
                if other["object_id"] != det["object_id"]:
                    if bbox_iou(det["bbox_xyxy"], other["bbox_xyxy"]) > 0.0:
                        has_overlap = True
                        break
            
            if has_overlap:
                conf = det.get("confidence", 0.0)
                label = f"D{suffix} {cat} {conf:.2f}"
            else:
                yolo_conf = det.get("yolo_confidence", 0.0)
                label = f"YOLO {suffix} {cat} {yolo_conf:.2f}"
                
            if det.get("coarse_verify_category_mismatch"):
                label += " MISMATCH"

        font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1
        (tw, th), bl = cv2.getTextSize(label, font, fscale, thick)
        
        ly = y1 - 5
        if ly - th - 2 < 0:
            ly = y2 + th + 5
            
        cv2.rectangle(overlay, (x1, ly - th - 2), (x1 + tw + 4, ly + bl), color, -1)
        cv2.putText(overlay, label, (x1 + 2, ly - 2), font, fscale, (255, 255, 255), thick, cv2.LINE_AA)

    # 5. Draw summary info box
    if vis_mode == "planner":
        summary_lines = [
            f"Planner detections: {len(detections)}",
            f"Approach candidates: {len(approach_candidates)}",
            f"Rejected: {len(rejected)}"
        ]
    else:
        summary_lines = [
            f"Candidates: {len(qwen_candidates)}",
            f"Detections: {len(detections)}",
            f"Approach:   {len(approach_candidates)}",
            f"Rejected:   {len(rejected)}"
        ]
    sy = 20
    for line in summary_lines:
        font, fscale, thick = cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1
        (tw, th), bl = cv2.getTextSize(line, font, fscale, thick)
        cv2.rectangle(overlay, (10, sy - th - 2), (10 + tw + 4, sy + bl), (0, 0, 0), -1)
        cv2.putText(overlay, line, (12, sy - 2), font, fscale, (255, 255, 255), thick, cv2.LINE_AA)
        sy += th + 10

    overlay_path.parent.mkdir(parents=True, exist_ok=True)
    cv2.imwrite(str(overlay_path), overlay)



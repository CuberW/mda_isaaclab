    parser.add_argument("--image",   required=False, default="", help="Path to input image")
    parser.add_argument("--model",   required=False, default="", help="Path to YOLO11-seg model (.pt)")
    parser.add_argument("--conf",    type=float, default=0.15,
                        help="YOLO confidence threshold")
    parser.add_argument("--min-area-ratio", type=float, default=0.0005,
                        help="Min bbox area / image area")
    parser.add_argument("--max-area-ratio", type=float, default=0.60,
                        help="Max bbox area / image area")
    parser.add_argument("--pipeline", default="qwen_first",
                        choices=["yolo_first", "qwen_first", "hybrid"],
                        help="Perception pipeline (default: qwen_first)")
    parser.add_argument("--verify-mode", default="planner_only",
                        choices=["all", "planner_only", "top1", "none"],
                        help="Qwen verify mode for crop verification (default: planner_only)")
    parser.add_argument("--qwen-verify-workers", type=int, default=4,
                        help="Number of threads for concurrent crop verification (default: 4)")
    parser.add_argument("--max-qwen-candidates", type=int, default=20,
                        help="Max Qwen coarse candidates to keep")
    parser.add_argument("--max-roi-refine", type=int, default=20,
                        help="Max candidates to run YOLO ROI refine on")
    parser.add_argument("--roi-expand", type=float, default=2.0,
                        help="Expand ratio for Qwen bbox -> ROI crop")
    parser.add_argument("--qwen-coarse-conf", type=float, default=0.55,
                        help="Min Qwen coarse confidence")
    parser.add_argument("--qwen-verify-conf", type=float, default=0.50,
                        help="Min Qwen verify confidence")
    parser.add_argument("--allow-unknown", action="store_true", default=False,
                        help="Allow unknown garbage_category in final detections")
    parser.add_argument("--include-approach-in-detections", action="store_true", default=False,
                        help="Include approach_required=true targets in final detections list")
    parser.add_argument("--vis-mode", default="planner",
                        choices=["planner", "debug"],
                        help="Visualization overlay mode (default: planner)")
    parser.add_argument("--save-vis", action="store_true",
                        help="Save overlay visualization")
    parser.add_argument("--qwen-api-check", action="store_true",
                        help="Only check Qwen API connectivity, skip YOLO/image")
    args = parser.parse_args()

    # --- Handle --qwen-api-check before anything else ---
    if args.qwen_api_check:
        print("=" * 60)
        print("[QWEN API CHECK]")
        print("=" * 60)
        api_key   = os.environ.get("QWEN_API_KEY",  "").strip()
        base_url  = os.environ.get("QWEN_BASE_URL", "").strip()
        model_name = os.environ.get("QWEN_MODEL", "").strip() or "qwen3-vl-flash"
        print(f"  QWEN_API_KEY   : {'SET (***' + api_key[-4:] + ')' if api_key else 'NOT SET'}")
        print(f"  QWEN_BASE_URL  : {base_url or 'NOT SET'}")
        print(f"  QWEN_MODEL     : {model_name}")
        # Check requests import (already imported at top)
        print(f"  requests       : OK (version {requests.__version__})")
        # Try import openai (optional)
        try:
            import openai
            print(f"  openai package : OK (version {openai.__version__})")
        except ImportError:
            print("  openai package : NOT installed (not required, using requests)")
        if not api_key or not base_url:
            print("[QWEN API CHECK] FAIL: missing QWEN_API_KEY or QWEN_BASE_URL")
            sys.exit(1)
        # Minimal text-only request (no image) to verify connectivity
        print("\n[QWEN API CHECK] Sending minimal text request...")
        headers = {"Authorization": f"Bearer {api_key}",
                   "Content-Type": "application/json"}
        data = {
            "model": model_name,
            "messages": [{"role": "user",
                           "content": [{"type": "text",
                                         "text": '\u53ea\u8f93\u51fa JSON\uff1a{"ok": true}'}]}],
        }
        url = f"{base_url.rstrip('/')}/chat/completions"
        try:
            resp = requests.post(url, headers=headers, json=data, timeout=20)
            print(f"  HTTP status    : {resp.status_code}")
            if resp.status_code == 200:
                content = resp.json()["choices"][0]["message"]["content"]
                print(f"  Response       : {content[:200]}")
                print("[QWEN API CHECK] OK")
            else:
                print(f"  Error body     : {resp.text[:300]}")
                print("[QWEN API CHECK] FAIL: non-200 response")
        except Exception as e:
            print(f"  Exception      : {repr(e)}")
            print("[QWEN API CHECK] FAIL: request exception")
        sys.exit(0)

    if args.pipeline == "hybrid":
        args.pipeline = "qwen_first"

    if not args.image:
        print("[ERROR] --image is required (unless using --qwen-api-check)")
        sys.exit(1)
    if not args.model:
        print("[ERROR] --model is required (unless using --qwen-api-check)")
        sys.exit(1)

    image_path = Path(args.image).expanduser().resolve()
    model_path = Path(args.model).expanduser().resolve()

    if not image_path.exists():
        print(f"[ERROR] Image not found: {image_path}")
        sys.exit(1)
    if not model_path.exists():
        print(f"[ERROR] Model not found: {model_path}")
        sys.exit(1)

    print(f"[START] pipeline={args.pipeline} | model={model_path.name}"
          f" | image={image_path.name}")

    img = cv2.imread(str(image_path))
    if img is None:
        print(f"[ERROR] Cannot read image: {image_path}")
        sys.exit(1)
    orig_h, orig_w = img.shape[:2]

    model = YOLO(str(model_path))
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    qwen_candidates_for_vis = []

    if args.pipeline == "yolo_first":
        crop_dir = ROOT / "data" / "crops" / "qwen" / timestamp
        crop_dir.mkdir(parents=True, exist_ok=True)
        detections, rejected_detections, infer_sec = run_yolo_first(
            image_path, model, args, img, orig_w, orig_h, crop_dir)

        # Split approach_candidates
        approach_candidates = []
        final_detections = []
        for d in detections:
            if d.get("approach_required", False) and not args.include_approach_in_detections:
                d["not_sent_to_planner_reason"] = "approach_required"
                approach_candidates.append(d)
            else:
                final_detections.append(d)
        detections = final_detections

        # Normalize rejected_detections reason field
        for r in rejected_detections:
            ex_reason = r.get("reason") or r.get("reject_reason") or r.get("rejected_reason") or r.get("status") or r.get("error_reason") or "unknown_rejection_reason"
            if ex_reason in ["invalid_qwen_bbox", "invalid_qwen_bbox_norm"]:
                mapped_reason = "invalid_qwen_bbox_norm"
            elif ex_reason in ["failed_yolo_refine", "no_yolo_detection_in_roi", "yolo_boxes_below_area_threshold"]:
                mapped_reason = "failed_yolo_refine"
            elif ex_reason in ["qwen_verify_not_graspable"]:
                mapped_reason = "qwen_verify_not_graspable"
            elif ex_reason == "duplicate_after_yolo_refine":
                mapped_reason = "duplicate_after_yolo_refine"
            else:
                mapped_reason = ex_reason
            r["reason"] = mapped_reason
            if "reject_reason" not in r:
                r["reject_reason"] = mapped_reason

        summary = {
            "mode":              "YOLO11_SEG_QWEN_PERCEPTION",
            "backend":           "yolo11_seg_qwen",
            "pipeline":          "yolo_first",
            "requested_pipeline": "yolo_first",
            "executed_pipeline": "yolo_first",
            "fallback_used":     False,
            "fallback_reason":   "none",
            "model":             str(model_path),
            "qwen_model":        os.environ.get("QWEN_MODEL", "qwen3-vl-flash"),
            "image":             str(image_path),
            "source_image":      str(image_path),
            "image_width":       int(orig_w),
            "image_height":      int(orig_h),
            "created_timestamp": time.time(),
            "inference_sec":     round(infer_sec, 4),
            "planner_ready":     check_planner_ready(detections),
            "num_detections":    len(detections),
            "num_approach_candidates": len(approach_candidates),
            "num_rejected":      len(rejected_detections),
            "verify_mode":       args.verify_mode,
            "num_qwen_verify_calls": len(detections) + len(approach_candidates),
            "num_qwen_verify_skipped": 0,
            "qwen_verify_workers": 1,
            "qwen_verify_parallel": False,
            "qwen_coarse_sec": 0.0,
            "yolo_roi_total_sec": 0.0,
            "qwen_verify_total_sec": 0.0,
            "yolo_roi_calls": 0,
            "detections":        detections,
            "approach_candidates": approach_candidates,
            "rejected_detections": rejected_detections,
        }

    else:  # qwen_first (default)
        _get_qwen_config()  # set QWEN_MOCK_MODE early
        # Clear raw log for this run
        try:
            DEFAULT_QWEN_RAW_LOG.parent.mkdir(parents=True, exist_ok=True)
            DEFAULT_QWEN_RAW_LOG.write_text(
                f"# Qwen raw responses — run started at {datetime.now().isoformat()}\n",
                encoding="utf-8")
        except Exception:
            pass

        (detections, rejected_detections, infer_sec,
         qwen_candidates_for_vis, fb_meta) = run_qwen_first(
            image_path, model, args, img, orig_w, orig_h, timestamp)

        # Split approach_candidates
        approach_candidates = []
        final_detections = []
        for d in detections:
            if d.get("approach_required", False) and not args.include_approach_in_detections:
                d["not_sent_to_planner_reason"] = "approach_required"
                approach_candidates.append(d)
            else:
                final_detections.append(d)
        detections = final_detections

        # Normalize rejected_detections reason field
        for r in rejected_detections:
            ex_reason = r.get("reason") or r.get("reject_reason") or r.get("rejected_reason") or r.get("status") or r.get("error_reason") or "unknown_rejection_reason"
            if ex_reason in ["invalid_qwen_bbox", "invalid_qwen_bbox_norm"]:
                mapped_reason = "invalid_qwen_bbox_norm"
            elif ex_reason in ["failed_yolo_refine", "no_yolo_detection_in_roi", "yolo_boxes_below_area_threshold"]:
                mapped_reason = "failed_yolo_refine"
            elif ex_reason in ["qwen_verify_not_graspable"]:
                mapped_reason = "qwen_verify_not_graspable"
            elif ex_reason == "duplicate_after_yolo_refine":
                mapped_reason = "duplicate_after_yolo_refine"
            else:
                mapped_reason = ex_reason
            r["reason"] = mapped_reason
            if "reject_reason" not in r:
                r["reject_reason"] = mapped_reason

        executed_pl = fb_meta.get("executed_pipeline", "qwen_first")
        fallback_used   = fb_meta.get("fallback_used", False)
        fallback_reason = fb_meta.get("fallback_reason", "none")

        if executed_pl == "yolo_first":
            _mode    = "YOLO11_SEG_QWEN_PERCEPTION"
            _backend = "yolo11_seg_qwen"
        else:
            _mode    = "YOLO11_QWEN_FIRST_ROI_PERCEPTION"
            _backend = "qwen_first_yolo11_roi"

        summary = {
            "mode":              _mode,
            "backend":           _backend,
            "pipeline":          executed_pl,
            "requested_pipeline": args.pipeline,
            "executed_pipeline": executed_pl,
            "fallback_used":     fallback_used,
            "fallback_reason":   fallback_reason,
            "model":             str(model_path),
            "qwen_model":        os.environ.get("QWEN_MODEL", "qwen3-vl-flash"),
            "image":             str(image_path),
            "source_image":      str(image_path),
            "image_width":       int(orig_w),
            "image_height":      int(orig_h),
            "created_timestamp": time.time(),
            "inference_sec":     round(infer_sec, 4),
            "planner_ready":     check_planner_ready(detections),
            "num_qwen_candidates": len(qwen_candidates_for_vis),
            "num_detections":    len(detections),
            "num_approach_candidates": len(approach_candidates),
            "num_rejected":      len(rejected_detections),
            "verify_mode":       fb_meta.get("verify_mode", args.verify_mode),
            "num_qwen_verify_calls": fb_meta.get("num_qwen_verify_calls", 0),
            "num_qwen_verify_skipped": fb_meta.get("num_qwen_verify_skipped", 0),
            "qwen_verify_workers": args.qwen_verify_workers if executed_pl == "qwen_first" else 1,
            "qwen_verify_parallel": (args.qwen_verify_workers > 1 and fb_meta.get("verify_mode", args.verify_mode) in ["all", "planner_only"]) if executed_pl == "qwen_first" else False,
            "qwen_coarse_sec": fb_meta.get("qwen_coarse_sec", 0.0) if executed_pl == "qwen_first" else 0.0,
            "yolo_roi_total_sec": fb_meta.get("yolo_roi_total_sec", 0.0) if executed_pl == "qwen_first" else 0.0,
            "qwen_verify_total_sec": fb_meta.get("qwen_verify_total_sec", 0.0) if executed_pl == "qwen_first" else 0.0,
            "yolo_roi_calls": fb_meta.get("yolo_roi_calls", 0) if executed_pl == "qwen_first" else 0,
            "detections":        detections,
            "approach_candidates": approach_candidates,
            "rejected_detections": rejected_detections,
        }

    save_json_atomic(DEFAULT_OUTPUT_JSON, summary)
    print(f"[SAVED] JSON -> {DEFAULT_OUTPUT_JSON}")
    print(f"[RESULT] {len(detections)} detections, "
          f"{len(approach_candidates)} approach, "
          f"{len(rejected_detections)} rejected")

    # Save summary latest txt
    summary_path = ROOT / "data" / "logs" / "yolo11_qwen_summary_latest.txt"
    if args.pipeline == "yolo_first" or summary.get("executed_pipeline") == "yolo_first":
        num_candidates = 0
        num_before = len(detections) + len(approach_candidates)
    else:
        num_candidates = len(qwen_candidates_for_vis)
        num_before = fb_meta.get("num_detections_before_dedup", len(detections) + len(approach_candidates))

    summary_data = {
        "image": str(image_path),
        "num_qwen_candidates": num_candidates,
        "num_detections_before_dedup": num_before,
        "num_detections_after_dedup": len(detections),
        "num_approach_candidates": len(approach_candidates),
        "num_rejected": len(rejected_detections),
        "planner_ready": summary.get("planner_ready", False),
        "verify_mode": summary.get("verify_mode", "none"),
        "num_qwen_verify_calls": summary.get("num_qwen_verify_calls", 0),
        "num_qwen_verify_skipped": summary.get("num_qwen_verify_skipped", 0),
        "qwen_verify_workers": summary.get("qwen_verify_workers", 1),
        "qwen_verify_parallel": summary.get("qwen_verify_parallel", False),
        "qwen_coarse_sec": summary.get("qwen_coarse_sec", 0.0),
        "yolo_roi_total_sec": summary.get("yolo_roi_total_sec", 0.0),
        "qwen_verify_total_sec": summary.get("qwen_verify_total_sec", 0.0),
        "yolo_roi_calls": summary.get("yolo_roi_calls", 0),
        "total_sec": summary.get("inference_sec", 0.0),
        "detections": detections,
        "approach_candidates": approach_candidates,
        "rejected_detections": rejected_detections,
    }
    save_summary_text(summary_path, summary_data)

    if args.save_vis:
        _use_yolo_overlay = (
            args.pipeline == "yolo_first" or
            summary.get("executed_pipeline") == "yolo_first"
        )
        if _use_yolo_overlay:
            draw_overlay_qwen(image_path, detections + approach_candidates, DEFAULT_OVERLAY)
        else:
            if args.vis_mode == "debug":
                overlay_path = ROOT / "data" / "logs" / "yolo11_qwen_overlay_debug_latest.jpg"
            else:
                overlay_path = ROOT / "data" / "logs" / "yolo11_qwen_overlay_latest.jpg"

            draw_overlay_qwen_first(
                image_path, detections, rejected_detections,
                qwen_candidates_for_vis, overlay_path,
                approach_candidates=approach_candidates,
                vis_mode=args.vis_mode)
            print(f"[SAVED] Overlay ({args.vis_mode}) -> {overlay_path}")

    print(json.dumps(summary, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
